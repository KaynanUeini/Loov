<% Rails.logger.info("Renderizando appointments/new.html.erb: @car_wash=#{@car_wash.inspect}") %>
<script>
  window.carWashId = <%= @car_wash.id %>;
  window.operatingHours = <%= @car_wash.operating_hours.map { |oh| { day_of_week: oh.day_of_week, opens_at: (oh.opens_at.hour * 60 + oh.opens_at.min), closes_at: (oh.closes_at.hour * 60 + oh.closes_at.min) } }.to_json.html_safe %>;
  window.capacityPerSlot = <%= @car_wash.capacity_per_slot %>;
  window.carWashName = "<%= @car_wash.name %>";
  window.carWashAddress = "<%= @car_wash.address %>";
</script>

<div id="loov-cursor"></div>
<div id="loov-cursor-trail"></div>
<div id="page-transition"></div>

<style>
  :root {
    --lime: #afff2d;
    --lime-dim: #8fcc24;
    --black: #000000;
    --surface: #0a0a0a;
    --surface-2: #0d0d0d;
    --surface-3: #141414;
    --border: #1a1a1a;
    --border-soft: #222;
    --text-muted: #444;
    --text-secondary: #777;
    --white: #ffffff;
  }

  /* ── CURSOR ─────────────────────────────────────────── */
  #loov-cursor { position:fixed;width:8px;height:8px;background:var(--lime);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .18s ease,height .18s ease;mix-blend-mode:difference; }
  #loov-cursor-trail { position:fixed;width:38px;height:38px;border:1px solid rgba(175,255,45,0.25);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .25s ease,height .25s ease,border-color .25s ease; }
  body.cursor-hover #loov-cursor { width:14px;height:14px; }
  body.cursor-hover #loov-cursor-trail { width:58px;height:58px;border-color:rgba(175,255,45,0.45); }
  @media(hover:none){#loov-cursor,#loov-cursor-trail{display:none;}}

  /* ── PAGE TRANSITION ─────────────────────────────────── */
  #page-transition { position:fixed;inset:0;z-index:10000;background:#000;transform:translateY(100%);pointer-events:none; }
  #page-transition.enter { animation:pgEnter .42s cubic-bezier(.76,0,.24,1) forwards; }
  #page-transition.exit  { animation:pgExit  .42s cubic-bezier(.76,0,.24,1) forwards; }
  @keyframes pgEnter { from{transform:translateY(100%)}to{transform:translateY(0)} }
  @keyframes pgExit  { from{transform:translateY(0)}to{transform:translateY(-100%)} }

  /* ── BASE ────────────────────────────────────────────── */
  * { box-sizing: border-box; }
  body { cursor: none; }

  .appt-wrap {
    min-height: 100vh;
    background: var(--black);
    font-family: 'DM Sans', sans-serif;
    padding-top: 60px;
  }

  .appt-back {
    max-width: 640px; margin: 0 auto;
    padding: 2rem 1.5rem 0;
    opacity: 0; animation: revealUp .6s cubic-bezier(.16,1,.3,1) forwards .05s;
  }
  .appt-back a {
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .8125rem; color: var(--text-muted);
    text-decoration: none; transition: color .2s ease; cursor: none;
  }
  .appt-back a:hover { color: var(--lime); }

  .appt-header {
    max-width: 640px; margin: 0 auto;
    padding: 2rem 1.5rem;
    opacity: 0; animation: revealUp .7s cubic-bezier(.16,1,.3,1) forwards .15s;
  }

  .appt-eyebrow {
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .68rem; font-weight: 500; letter-spacing: .25em;
    text-transform: uppercase; color: var(--lime); margin-bottom: 1rem;
  }
  .appt-eyebrow::before { content:''; display:block; width:24px; height:1px; background:var(--lime); }

  .appt-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 7vw, 4rem);
    line-height: .95; color: var(--white); margin-bottom: .5rem;
  }
  .appt-title span { color: var(--lime); }
  .appt-subtitle { font-size: .9rem; color: var(--text-muted); }

  .appt-flash { max-width: 640px; margin: 0 auto; padding: 0 1.5rem 1rem; }
  .appt-flash-msg { display: flex; align-items: center; gap: .75rem; padding: .875rem 1.25rem; border-radius: 12px; font-size: .875rem; margin-bottom: .75rem; }
  .appt-flash-msg.error   { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.2); color: #fca5a5; }
  .appt-flash-msg.success { background: rgba(175,255,45,.08); border: 1px solid rgba(175,255,45,.15); color: var(--lime); }

  .appt-divider { max-width: 640px; margin: 0 auto; padding: 0 1.5rem; }
  .appt-divider-line { height: 1px; background: var(--border); }

  .appt-screens { max-width: 640px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .appt-screen { transition: opacity .35s ease, transform .35s ease; }
  .appt-screen.hidden { display: none; }

  /* ── STEPS ───────────────────────────────────────────── */
  .appt-steps { display: flex; align-items: center; gap: .5rem; margin-bottom: 2.5rem; }
  .appt-step { display: flex; align-items: center; gap: .4rem; font-size: .75rem; font-weight: 500; color: var(--text-muted); transition: color .2s ease; }
  .appt-step-num { width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: .65rem; font-weight: 700; flex-shrink: 0; transition: all .2s ease; }
  .appt-step.active { color: var(--white); }
  .appt-step.active .appt-step-num { background: var(--lime); color: var(--black); border-color: var(--lime); }
  .appt-step.done { color: var(--lime); }
  .appt-step.done .appt-step-num { background: transparent; color: var(--lime); border-color: var(--lime); }
  .appt-step-divider { flex: 1; height: 1px; background: var(--border); }

  /* ── FIELDS ──────────────────────────────────────────── */
  .appt-field { margin-bottom: 2rem; }
  .appt-label { display: flex; align-items: center; gap: .5rem; font-size: .8125rem; font-weight: 500; color: var(--text-secondary); margin-bottom: .625rem; text-transform: uppercase; letter-spacing: .08em; }
  .appt-label i { color: var(--lime); font-size: .7rem; }

  /* Campo bloqueado */
  .field-locked-wrap { opacity: .4; pointer-events: none; transition: opacity .25s ease; }
  .field-locked-wrap.unlocked { opacity: 1; pointer-events: auto; }

  .field-hint { display: none; align-items: center; gap: .4rem; font-size: .78rem; color: var(--text-muted); margin-top: .5rem; padding: .5rem .75rem; background: var(--surface-2); border: 1px dashed var(--border); border-radius: 8px; }
  .appt-field.locked .field-hint { display: flex; }

  .appt-input {
    width: 100%; background: var(--surface-2); border: 1px solid var(--border);
    border-radius: 10px; padding: .875rem 1rem;
    font-family: 'DM Sans', sans-serif; font-size: .9375rem; color: var(--white);
    transition: all .2s ease; outline: none; appearance: none; cursor: none;
  }
  .appt-input::placeholder { color: var(--text-muted); }
  .appt-input:focus { border-color: var(--lime); box-shadow: 0 0 0 3px rgba(175,255,45,.07); }

  /* ── SERVICE CARDS ───────────────────────────────────── */
  .service-cards { display: flex; flex-direction: column; gap: .75rem; }
  .service-card {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem; background: var(--surface-2);
    border: 1px solid var(--border); border-radius: 12px;
    cursor: none; transition: all .2s ease; gap: 1rem;
    position: relative; overflow: hidden;
  }
  .service-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:2px; background:var(--lime); transform:scaleY(0); transform-origin:bottom; transition:transform .3s cubic-bezier(.16,1,.3,1); }
  .service-card:hover { border-color: rgba(175,255,45,.2); background: var(--surface-3); }
  .service-card:hover::before { transform: scaleY(1); }
  .service-card.selected { border-color: var(--lime); background: var(--surface-3); box-shadow: 0 0 0 1px var(--lime); }
  .service-card.selected::before { transform: scaleY(1); }

  .service-card-left { flex: 1; }
  .service-card-name { font-size: .9375rem; font-weight: 500; color: var(--white); margin-bottom: .2rem; }
  .service-card-meta { font-size: .8rem; color: var(--text-muted); display: flex; align-items: center; gap: .5rem; }
  .service-card-meta i { color: var(--lime); font-size: .65rem; }
  .service-card-price { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: var(--lime); letter-spacing: .02em; flex-shrink: 0; }
  .service-card-check { width: 20px; height: 20px; border-radius: 50%; border: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all .2s ease; font-size: .6rem; color: transparent; }
  .service-card.selected .service-card-check { background: var(--lime); border-color: var(--lime); color: var(--black); }

  /* ── TIME SLOTS ──────────────────────────────────────── */
  .time-slots-container { display: flex; flex-wrap: wrap; gap: .5rem; }
  .time-slot { padding: .625rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2); color: var(--text-secondary); font-size: .875rem; font-weight: 500; cursor: none; transition: all .15s ease; font-variant-numeric: tabular-nums; }
  .time-slot:hover { border-color: var(--lime); color: var(--lime); }
  .time-slot.selected { background: var(--lime); color: var(--black); border-color: var(--lime); font-weight: 600; }

  #loading-indicator { font-size: .8125rem; color: var(--lime); display: flex; align-items: center; gap: .5rem; padding: .5rem 0; }
  #time-error { font-size: .8rem; color: #fca5a5; display: flex; align-items: center; gap: .5rem; }

  /* ── SUMMARY ─────────────────────────────────────────── */
  .summary-card {
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: 20px; overflow: hidden; margin-bottom: 1rem;
    position: relative;
  }
  .summary-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:2px; background:var(--lime); }

  .summary-card-header {
    padding: 1.25rem 1.5rem 1.25rem 1.75rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 1rem;
  }

  .summary-avatar {
    width: 48px; height: 48px; border-radius: 12px;
    background: linear-gradient(135deg, #141414, #1e1e1e);
    border: 1px solid var(--border-soft);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; color: var(--lime); flex-shrink: 0;
  }

  .summary-car-wash-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.25rem; color: var(--white); letter-spacing: .02em; }
  .summary-car-wash-address { font-size: .8rem; color: var(--text-muted); margin-top: .15rem; }

  .summary-rows { padding: .5rem 0; }
  .summary-row { display: flex; align-items: center; justify-content: space-between; padding: .75rem 1.5rem .75rem 1.75rem; border-bottom: 1px solid var(--border); gap: 1rem; }
  .summary-row:last-child { border-bottom: none; }
  .summary-row-label { font-size: .8125rem; color: var(--text-muted); flex-shrink: 0; }
  .summary-row-value { font-size: .875rem; color: var(--white); text-align: right; }
  .summary-row-value.highlight { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: var(--lime); letter-spacing: .02em; }

  /* ── EMAIL NOTICE ────────────────────────────────────── */
  .email-notice {
    display: flex; align-items: center; gap: .75rem;
    padding: .875rem 1.25rem;
    background: rgba(175,255,45,.04); border: 1px solid rgba(175,255,45,.1);
    border-radius: 12px; margin-bottom: 1.25rem;
    font-size: .82rem; color: var(--text-muted); line-height: 1.4;
  }
  .email-notice i { color: var(--lime); font-size: .85rem; flex-shrink: 0; }
  .email-notice strong { color: var(--white); }

  /* ── ACTIONS ─────────────────────────────────────────── */
  .appt-actions { display: flex; gap: .75rem; flex-wrap: wrap; }

  .btn-appt {
    display: inline-flex; align-items: center; justify-content: center; gap: .5rem;
    padding: .875rem 1.75rem; border-radius: 100px;
    font-family: 'DM Sans', sans-serif; font-size: .875rem; font-weight: 500;
    text-decoration: none; transition: all .2s ease; cursor: none; border: none; white-space: nowrap;
  }
  .btn-appt-primary { background: var(--lime); color: var(--black); flex: 1; }
  .btn-appt-primary:hover:not(:disabled) { background: var(--lime-dim); transform: translateY(-2px); }
  .btn-appt-primary:disabled { opacity: .45; cursor: not-allowed; transform: none; }
  .btn-appt-secondary { background: transparent; color: var(--white); border: 1px solid var(--border-soft); }
  .btn-appt-secondary:hover { border-color: var(--lime); color: var(--lime); }

  /* Spinner inline no botão */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin .8s linear infinite; display: inline-block; }

  /* ── FLATPICKR ───────────────────────────────────────── */
  .flatpickr-input { cursor: none !important; }
  .flatpickr-calendar { background: var(--surface-2) !important; border: 1px solid var(--border) !important; border-radius: 12px !important; box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important; }
  .flatpickr-day { color: var(--white) !important; border-radius: 8px !important; }
  .flatpickr-day:hover { background: var(--surface-3) !important; border-color: var(--lime) !important; }
  .flatpickr-day.selected, .flatpickr-day.selected:hover { background: var(--lime) !important; color: var(--black) !important; border-color: var(--lime) !important; font-weight: 700 !important; }
  .flatpickr-day.disabled, .flatpickr-day.disabled:hover { color: var(--border) !important; cursor: not-allowed !important; }
  .flatpickr-day.nextMonthDay, .flatpickr-day.prevMonthDay { color: var(--border) !important; pointer-events: none !important; }
  .flatpickr-month { color: var(--white) !important; }
  .flatpickr-current-month, .flatpickr-current-month span, .flatpickr-current-month input { color: var(--white) !important; font-family: 'Bebas Neue', sans-serif !important; font-size: 1rem !important; }
  .flatpickr-weekday { color: var(--lime) !important; font-size: .7rem !important; font-weight: 600 !important; }
  .flatpickr-prev-month svg, .flatpickr-next-month svg { fill: var(--white) !important; }
  .flatpickr-prev-month:hover svg, .flatpickr-next-month:hover svg { fill: var(--lime) !important; }

  /* ── ANIMAÇÕES ───────────────────────────────────────── */
  @keyframes revealUp { from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)} }
  @keyframes slideIn  { from{opacity:0;transform:translateX(32px)}to{opacity:1;transform:translateX(0)} }
  .screen-enter { animation: slideIn .35s ease forwards; }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media(max-width:640px) {
    .appt-back, .appt-header, .appt-divider, .appt-screens, .appt-flash { padding-left: 1.25rem; padding-right: 1.25rem; }
  }
</style>

<div class="appt-wrap">

  <div class="appt-back">
    <a href="#" id="back-btn">
      <i class="fas fa-arrow-left"></i> <span id="back-label">Voltar</span>
    </a>
  </div>

  <div class="appt-header">
    <div class="appt-eyebrow">Novo Agendamento</div>
    <h1 class="appt-title">
      Agendar em<span> <%= @car_wash&.name || "Lava-rápido" %>.</span>
    </h1>
    <p class="appt-subtitle"><%= @car_wash&.address %></p>
  </div>

  <% if flash[:alert] || flash[:notice] %>
  <div class="appt-flash">
    <% if flash[:alert] %>
      <div class="appt-flash-msg error"><i class="fas fa-circle-exclamation"></i><span><%= flash[:alert] %></span></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="appt-flash-msg success"><i class="fas fa-circle-check"></i><span><%= flash[:notice] %></span></div>
    <% end %>
  </div>
  <% end %>

  <div class="appt-divider"><div class="appt-divider-line"></div></div>

  <div class="appt-screens">

    <!-- TELA 1: Seleção -->
    <div id="screen-selection" class="appt-screen">

      <div class="appt-steps">
        <div class="appt-step active" id="step-1"><div class="appt-step-num">1</div><span>Data</span></div>
        <div class="appt-step-divider"></div>
        <div class="appt-step" id="step-2"><div class="appt-step-num">2</div><span>Serviço</span></div>
        <div class="appt-step-divider"></div>
        <div class="appt-step" id="step-3"><div class="appt-step-num">3</div><span>Horário</span></div>
      </div>

      <!-- Data -->
      <div class="appt-field">
        <label class="appt-label"><i class="fas fa-calendar"></i> Data *</label>
        <input type="text" id="appointment-date" class="appt-input" placeholder="Selecione uma data" readonly>
      </div>

      <!-- Serviço -->
      <div class="appt-field locked" id="field-service">
        <label class="appt-label"><i class="fas fa-wrench"></i> Serviço *</label>
        <div class="field-locked-wrap" id="wrap-service">
          <div class="service-cards" id="service-cards">
            <% @car_wash.services.each do |service| %>
              <div class="service-card"
                data-id="<%= service.id %>"
                data-price="<%= service.price.to_f %>"
                data-duration="<%= service.duration %>"
                data-title="<%= service.title %>">
                <div class="service-card-left">
                  <div class="service-card-name"><%= service.title %></div>
                  <div class="service-card-meta">
                    <i class="fas fa-clock"></i> <%= service.duration %> min
                    <% if service.description.present? %>
                      · <%= service.description.truncate(40) %>
                    <% end %>
                  </div>
                </div>
                <div class="service-card-price">R$&nbsp;<%= number_with_precision(service.price, precision: 2, separator: ',') %></div>
                <div class="service-card-check"><i class="fas fa-check"></i></div>
              </div>
            <% end %>
          </div>
        </div>
        <div class="field-hint">
          <i class="fas fa-arrow-up"></i>
          <span>Selecione uma data primeiro para liberar este campo.</span>
        </div>
      </div>

      <!-- Horário -->
      <div class="appt-field locked" id="field-time">
        <label class="appt-label"><i class="fas fa-clock"></i> Horário *</label>
        <div class="field-locked-wrap" id="wrap-time">
          <div id="loading-indicator" style="display:none;">
            <i class="fas fa-spinner fa-spin"></i> Carregando horários...
          </div>
          <div id="time-error" style="display:none;">
            <i class="fas fa-circle-exclamation"></i>&nbsp;<span id="time-error-msg">Nenhum horário disponível.</span>
          </div>
          <div id="time-slots" class="time-slots-container"></div>
        </div>
        <div class="field-hint">
          <i class="fas fa-arrow-up"></i>
          <span>Escolha um serviço primeiro para ver os horários disponíveis.</span>
        </div>
      </div>

    </div>

    <!-- TELA 2: Resumo -->
    <div id="screen-summary" class="appt-screen hidden">

      <%= form_with(model: @appointment, local: true, id: "appointment-form") do |form| %>
        <%= form.hidden_field :car_wash_id, value: @car_wash.id %>
        <%= form.hidden_field :service_id, id: "hidden-service-id" %>
        <%= form.hidden_field :date, id: "hidden-date" %>
        <%= form.hidden_field :time, id: "hidden-time" %>

        <div class="summary-card">
          <div class="summary-card-header">
            <div class="summary-avatar"><%= @car_wash.name.first(2).upcase %></div>
            <div>
              <div class="summary-car-wash-name"><%= @car_wash.name %></div>
              <div class="summary-car-wash-address"><%= @car_wash.address %></div>
            </div>
          </div>
          <div class="summary-rows">
            <div class="summary-row"><span class="summary-row-label">Data</span><span class="summary-row-value" id="sum-date">—</span></div>
            <div class="summary-row"><span class="summary-row-label">Horário</span><span class="summary-row-value" id="sum-time">—</span></div>
            <div class="summary-row"><span class="summary-row-label">Serviço</span><span class="summary-row-value" id="sum-service">—</span></div>
            <div class="summary-row"><span class="summary-row-label">Duração</span><span class="summary-row-value" id="sum-duration">—</span></div>
            <div class="summary-row"><span class="summary-row-label">Valor</span><span class="summary-row-value highlight" id="sum-price">—</span></div>
          </div>
        </div>

        <div class="email-notice">
          <i class="fas fa-envelope"></i>
          <span>Após confirmar, você receberá um <strong>e-mail de confirmação</strong> com todos os detalhes.</span>
        </div>

        <div class="appt-actions">
          <button type="button" class="btn-appt btn-appt-secondary" id="btn-back-selection">
            <i class="fas fa-arrow-left"></i> Corrigir
          </button>
          <%= form.submit "Confirmar Agendamento",
              class: "btn-appt btn-appt-primary",
              id: "submit-button",
              data: { disable_with: "Confirmando..." } %>
        </div>

      <% end %>
    </div>

  </div>
</div>

<script>
  var selectedDate = null;
  var selectedDateStr = null;
  var selectedDuration = null;
  var selectedServiceId = null;
  var selectedServiceTitle = null;
  var selectedServicePrice = null;

  // ── CURSOR ────────────────────────────────────────────
  (function() {
    const cursor = document.getElementById('loov-cursor');
    const trail  = document.getElementById('loov-cursor-trail');
    if (!cursor || !trail) return;
    let mx=-100,my=-100,tx=-100,ty=-100;
    document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});
    (function anim(){tx+=(mx-tx)*0.12;ty+=(my-ty)*0.12;trail.style.left=tx+'px';trail.style.top=ty+'px';requestAnimationFrame(anim);})();
    document.addEventListener('mouseover',e=>{if(e.target.closest('a,button,input,select,textarea'))document.body.classList.add('cursor-hover');});
    document.addEventListener('mouseout', e=>{if(e.target.closest('a,button,input,select,textarea'))document.body.classList.remove('cursor-hover');});
    document.addEventListener('mouseleave',()=>{cursor.style.opacity='0';trail.style.opacity='0';});
    document.addEventListener('mouseenter',()=>{cursor.style.opacity='1';trail.style.opacity='1';});
  })();

  // ── PAGE TRANSITION ───────────────────────────────────
  (function() {
    const pt = document.getElementById('page-transition');
    if (!pt) return;
    window.addEventListener('pageshow',()=>{pt.classList.remove('enter');pt.classList.add('exit');setTimeout(()=>pt.classList.remove('exit'),440);});
  })();

  // ── HELPERS ───────────────────────────────────────────
  function setStep(step) {
    for (var i = 1; i <= 3; i++) {
      var el = document.getElementById('step-' + i);
      el.classList.remove('active', 'done');
      if (i < step) el.classList.add('done');
      else if (i === step) el.classList.add('active');
    }
  }

  function unlockField(fieldId, wrapId) {
    var f = document.getElementById(fieldId);
    var w = document.getElementById(wrapId);
    if (f) f.classList.remove('locked');
    if (w) w.classList.add('unlocked');
  }

  function lockField(fieldId, wrapId) {
    var f = document.getElementById(fieldId);
    var w = document.getElementById(wrapId);
    if (f) f.classList.add('locked');
    if (w) w.classList.remove('unlocked');
  }

  function showScreen(id) {
    document.querySelectorAll('.appt-screen').forEach(function(s) { s.classList.add('hidden'); });
    var screen = document.getElementById(id);
    screen.classList.remove('hidden');
    screen.classList.add('screen-enter');
    setTimeout(function() { screen.classList.remove('screen-enter'); }, 400);
  }

  function showSummary() {
    var date = selectedDate;
    document.getElementById('sum-date').textContent =
      date.toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });
    document.getElementById('sum-time').textContent = document.getElementById('hidden-time').value;
    document.getElementById('sum-service').textContent = selectedServiceTitle;
    document.getElementById('sum-duration').textContent = selectedDuration + ' min';
    document.getElementById('sum-price').textContent = 'R$ ' + parseFloat(selectedServicePrice).toFixed(2).replace('.', ',');
    showScreen('screen-summary');
    document.getElementById('back-label').textContent = 'Voltar';
  }

  // ── BACK ──────────────────────────────────────────────
  document.getElementById('back-btn').addEventListener('click', function(e) {
    e.preventDefault();
    var summaryVisible = !document.getElementById('screen-summary').classList.contains('hidden');
    if (summaryVisible) {
      showScreen('screen-selection');
      document.getElementById('back-label').textContent = 'Voltar';
    } else {
      window.location.href = '<%= car_wash_path(@car_wash) %>';
    }
  });

  document.getElementById('btn-back-selection').addEventListener('click', function() {
    showScreen('screen-selection');
  });

  // ── SERVICE CARDS ─────────────────────────────────────
  document.querySelectorAll('.service-card').forEach(function(card) {
    card.addEventListener('click', function() {
      document.querySelectorAll('.service-card').forEach(function(c) { c.classList.remove('selected'); });
      card.classList.add('selected');
      selectedServiceId    = card.dataset.id;
      selectedServiceTitle = card.dataset.title;
      selectedServicePrice = card.dataset.price;
      selectedDuration     = parseInt(card.dataset.duration);
      document.getElementById('hidden-service-id').value = selectedServiceId;
      document.getElementById('time-slots').innerHTML = '';
      document.getElementById('time-error').style.display = 'none';
      document.getElementById('hidden-time').value = '';
      lockField('field-time', 'wrap-time');
      setStep(3);
      if (selectedDateStr) loadTimeSlots();
    });
  });

  // ── TIME SLOTS ────────────────────────────────────────
  async function loadTimeSlots() {
    if (!selectedDateStr || !selectedDuration) return;
    var dayOfWeek = selectedDate.getDay();
    var oh = (window.operatingHours || []).find(function(o) { return o.day_of_week === dayOfWeek; });
    if (!oh) {
      document.getElementById('time-error-msg').textContent = 'Lava-rápido fechado neste dia.';
      document.getElementById('time-error').style.display = 'flex';
      unlockField('field-time', 'wrap-time');
      return;
    }
    document.getElementById('loading-indicator').style.display = 'flex';
    document.getElementById('time-slots').innerHTML = '';
    document.getElementById('time-error').style.display = 'none';
    var appointments = [];
    try {
      var r = await fetch('/appointments.json?car_wash_id=' + window.carWashId + '&date=' + selectedDateStr, {
        headers: { 'Accept': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content }
      });
      var data = await r.json();
      appointments = data.appointments || [];
    } catch(e) { console.error(e); }
    document.getElementById('loading-indicator').style.display = 'none';
    var slots = [];
    var cur = oh.opens_at;
    var now = new Date();
    var isToday = selectedDate.toDateString() === now.toDateString();
    var nowMin  = now.getHours() * 60 + now.getMinutes();
    while (cur + selectedDuration <= oh.closes_at) {
      if (!isToday || cur > nowMin) {
        var used = appointments.filter(function(a) {
          var t = a.start_time ? a.start_time.match(/T(\d{2}):(\d{2})/) : null;
          if (!t) return false;
          var m = parseInt(t[1]) * 60 + parseInt(t[2]);
          return m < cur + selectedDuration && m + selectedDuration > cur;
        }).length;
        if ((window.capacityPerSlot || 1) - used > 0) {
          var h = String(Math.floor(cur/60)).padStart(2,'0');
          var m = String(cur%60).padStart(2,'0');
          slots.push({ time: h + ':' + m });
        }
      }
      cur += selectedDuration;
    }
    var container = document.getElementById('time-slots');
    if (!slots.length) {
      document.getElementById('time-error-msg').textContent = 'Nenhum horário disponível para este dia.';
      document.getElementById('time-error').style.display = 'flex';
      unlockField('field-time', 'wrap-time');
      return;
    }
    slots.forEach(function(s) {
      var slotEl = document.createElement('div');
      slotEl.className = 'time-slot';
      slotEl.textContent = s.time;
      slotEl.dataset.time = s.time;
      slotEl.addEventListener('click', function() {
        document.querySelectorAll('.time-slot').forEach(function(t) { t.classList.remove('selected'); });
        slotEl.classList.add('selected');
        document.getElementById('hidden-time').value = s.time;
        document.getElementById('hidden-date').value = selectedDateStr;
        setTimeout(showSummary, 250);
      });
      container.appendChild(slotEl);
    });
    unlockField('field-time', 'wrap-time');
  }

  // ── SUBMIT COM TRAVA ──────────────────────────────────
  document.getElementById('appointment-form')?.addEventListener('submit', function() {
    var btn = document.getElementById('submit-button');
    if (btn) {
      btn.disabled = true;
      btn.style.opacity = '0.5';
      btn.value = 'Confirmando...';
    }
  });

  // ── FLATPICKR ─────────────────────────────────────────
  function initFlatpickr() {
    var el = document.getElementById('appointment-date');
    if (!el || typeof flatpickr === 'undefined') { setTimeout(initFlatpickr, 50); return; }
    var today = new Date(); today.setHours(0,0,0,0);
    var maxDate = new Date(today); maxDate.setMonth(maxDate.getMonth() + 1);
    flatpickr(el, {
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "d/m/Y",
      minDate: today,
      maxDate: maxDate,
      showMonths: 1,
      disableMobile: true,
      locale: {
        firstDayOfWeek: 0,
        weekdays: {
          shorthand: ["Dom","Seg","Ter","Qua","Qui","Sex","Sab"],
          longhand:  ["Domingo","Segunda","Terça","Quarta","Quinta","Sexta","Sábado"]
        },
        months: {
          shorthand: ["Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"],
          longhand:  ["Janeiro","Fevereiro","Março","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"]
        }
      },
      onChange: function(selectedDates, dateStr) {
        if (!selectedDates.length) return;
        selectedDate    = selectedDates[0];
        selectedDateStr = dateStr;
        document.getElementById('hidden-date').value = dateStr;
        var dayOfWeek = selectedDate.getDay();
        var oh = (window.operatingHours || []).find(function(o) { return o.day_of_week === dayOfWeek; });
        document.querySelectorAll('.service-card').forEach(function(c) { c.classList.remove('selected'); });
        selectedServiceId = null; selectedDuration = null;
        document.getElementById('time-slots').innerHTML = '';
        document.getElementById('time-error').style.display = 'none';
        document.getElementById('hidden-time').value = '';
        lockField('field-time', 'wrap-time');
        if (!oh) {
          lockField('field-service', 'wrap-service');
          document.getElementById('time-error-msg').textContent = 'Lava-rápido fechado neste dia.';
          document.getElementById('time-error').style.display = 'flex';
          unlockField('field-time', 'wrap-time');
          setStep(1);
          return;
        }
        unlockField('field-service', 'wrap-service');
        setStep(2);
      }
    });
  }

  initFlatpickr();
</script>
