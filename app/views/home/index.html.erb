    <div class="home-section-header">
      <span class="home-section-title">Disponíveis agora</span>
      <% if @disponivel_has_location %><%= link_to "Ver mais", disponivel_index_path(latitude: params[:latitude], longitude: params[:longitude]), class: "home-section-link" %><% end %>
