        <div class="home-location-btn" style="cursor:default;"><i class="fas fa-location-dot"></i><span class="home-location-text"><%= @location_name %></span></div>
      <% elsif params[:latitude].present? %>
        <div class="home-location-btn" style="cursor:default;"><i class="fas fa-location-dot"></i><span>Localização ativa</span></div>
      <% else %>
        <button type="button" class="home-location-btn" onclick="requestGeo()"><i class="fas fa-location-dot"></i><span>Usar localização</span></button>
      <% end %>
    </div>
    <% end %>
  </div>

  <% if user_signed_in? && current_user.client? %>
