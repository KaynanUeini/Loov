      <div class="cw-card" onclick="window.location='<%= car_wash_path(cw) %>'" style="cursor:none;">
        <div class="cw-card-top"><div class="cw-card-avatar"><%= cw.name.first(2).upcase %></div><div class="cw-card-avatar-info"><div class="cw-card-name"><%= cw.name %></div><% if avg_rating %><div style="display:flex;align-items:center;gap:.2rem;flex-wrap:wrap;"><div class="cw-card-stars"><% 5.times do |s| %><i class="fas fa-star" style="color:<%= s < avg_rating.round ? '#afff2d' : '#333' %>;"></i><% end %></div><span class="cw-card-rating-val"><%= sprintf('%.1f', avg_rating) %></span><span class="cw-card-rating-ct">(<%= reviews.count %>)</span></div><% end %></div></div>
        <div class="cw-card-meta"><div class="cw-card-addr"><i class="fas fa-location-dot"></i><span><%= cw.address || "Endereço não informado" %></span></div><div class="cw-card-row"><% if is_open %><div class="cw-status-open"><div class="cw-status-open-dot"></div>ABERTO AGORA</div><% elsif opens_today %><div class="cw-status-closed">ABRE ÀS <%= opens_today.opens_at.strftime("%H:%M") %></div><% else %><div class="cw-status-closed">FECHADO HOJE</div><% end %><% if params[:latitude].present? && cw.latitude && cw.longitude %><span class="cw-card-dist"><%= number_with_precision(cw.distance_to([params[:latitude].to_f, params[:longitude].to_f], :km), precision: 1) %> KM</span><% end %></div></div>
        <%= link_to "Ver detalhes", car_wash_path(cw), class: "cw-card-btn" %>
      </div>
      <% end %>
    </div>
    <% end %>
  </div>

  <div class="home-divider"><div class="home-divider-line"></div></div>

  <div class="home-section">
    <div class="home-section-header">
      <span class="home-section-title">Top Performance</span>
      <%= link_to "Ver mais", car_washes_path(sort: 'top_rated'), class: "home-section-link" %>
    </div>
    <% if @top_car_washes.any? %>
    <div class="h-scroll">
      <% @top_car_washes.each do |cw| %>
      <% min_price=cw.services.minimum(:price); reviews=cw.reviews; avg_rating=reviews.any? ? reviews.average(:rating).to_f : nil; today_dow=Date.current.wday; is_open=cw.operating_hours.exists?(day_of_week: today_dow); opens_today=cw.operating_hours.find_by(day_of_week: today_dow) %>
      <div class="cw-card" onclick="window.location='<%= car_wash_path(cw) %>'" style="cursor:none;">
        <div class="cw-card-top"><div class="cw-card-avatar"><%= cw.name.first(2).upcase %></div><div class="cw-card-avatar-info"><div class="cw-card-name"><%= cw.name %></div><% if avg_rating %><div style="display:flex;align-items:center;gap:.2rem;flex-wrap:wrap;"><div class="cw-card-stars"><% 5.times do |s| %><i class="fas fa-star" style="color:<%= s < avg_rating.round ? '#afff2d' : '#333' %>;"></i><% end %></div><span class="cw-card-rating-val"><%= sprintf('%.1f', avg_rating) %></span><span class="cw-card-rating-ct">(<%= reviews.count %>)</span></div><% else %><div style="font-size:.68rem;color:#333;margin-top:.15rem;">Sem avaliações ainda</div><% end %></div></div>
        <div class="cw-card-meta"><div class="cw-card-addr"><i class="fas fa-location-dot"></i><span><%= cw.address || "Endereço não informado" %></span></div><% if min_price %><div style="font-size:.75rem;color:var(--text-muted);display:flex;align-items:center;gap:.3rem;"><i class="fas fa-tag" style="font-size:.6rem;"></i>A partir de <strong style="color:var(--white);margin-left:.2rem;">R$ <%= number_with_precision(min_price, precision: 0) %></strong></div><% end %><div class="cw-card-row"><% if is_open %><div class="cw-status-open"><div class="cw-status-open-dot"></div>ABERTO AGORA</div><% elsif opens_today %><div class="cw-status-closed">ABRE ÀS <%= opens_today.opens_at.strftime("%H:%M") %></div><% else %><div class="cw-status-closed">FECHADO HOJE</div><% end %></div></div>
        <%= link_to "Ver detalhes", car_wash_path(cw), class: "cw-card-btn" %>
      </div>
      <% end %>
    </div>
    <% end %>
  </div>

  <% if params[:search].present? %>
  <div class="home-divider"><div class="home-divider-line"></div></div>
  <div class="home-section">
    <div class="home-section-header"><span class="home-section-title">Resultados para "<%= params[:search] %>"</span><span style="font-size:.78rem;color:var(--text-muted);"><%= @car_washes.count %> encontrado<%= @car_washes.count == 1 ? '' : 's' %></span></div>
    <% if @car_washes.empty? %>
      <div class="empty-banner"><i class="fas fa-magnifying-glass"></i><div><div class="empty-banner-title">Nenhum resultado</div><div class="empty-banner-text">Tente outro nome ou bairro.</div></div></div>
    <% else %>
    <div class="h-scroll">
      <% @car_washes.each do |cw| %>
      <% reviews=cw.reviews; avg_rating=reviews.any? ? reviews.average(:rating).to_f : nil; today_dow=Date.current.wday; is_open=cw.operating_hours.exists?(day_of_week: today_dow) %>
      <div class="cw-card" onclick="window.location='<%= car_wash_path(cw) %>'" style="cursor:none;">
        <div class="cw-card-top"><div class="cw-card-avatar"><%= cw.name.first(2).upcase %></div><div class="cw-card-avatar-info"><div class="cw-card-name"><%= cw.name %></div><% if avg_rating %><div style="display:flex;align-items:center;gap:.2rem;"><div class="cw-card-stars"><% 5.times do |s| %><i class="fas fa-star" style="color:<%= s < avg_rating.round ? '#afff2d' : '#333' %>;"></i><% end %></div><span class="cw-card-rating-val"><%= sprintf('%.1f', avg_rating) %></span></div><% end %></div></div>
        <div class="cw-card-meta"><div class="cw-card-addr"><i class="fas fa-location-dot"></i><span><%= cw.address || "Endereço não informado" %></span></div><div class="cw-card-row"><% if is_open %><div class="cw-status-open"><div class="cw-status-open-dot"></div>ABERTO AGORA</div><% else %><div class="cw-status-closed">FECHADO HOJE</div><% end %></div></div>
        <%= link_to "Ver detalhes", car_wash_path(cw), class: "cw-card-btn" %>
      </div>
      <% end %>
    </div>
    <% end %>
  </div>
  <% end %>

  <div class="home-divider"><div class="home-divider-line"></div></div>
  <footer class="loov-footer">
    <a href="/" class="loov-footer-logo">LOOV<span>.</span></a>
    <ul class="loov-footer-links"><%= link_to "Lava-rápidos", car_washes_path %><% if user_signed_in? %><%= link_to "Meus agendamentos", appointments_path %><% else %><%= link_to "Entrar", new_user_session_path %><%= link_to "Criar conta", new_user_registration_path %><% end %></ul>
    <span class="loov-footer-copy">© <%= Date.current.year %> Loov</span>
  </footer>
</div>

<script>
(function(){
  const cursor=document.getElementById('loov-cursor'),trail=document.getElementById('loov-cursor-trail');
  if(cursor&&trail){let mx=-100,my=-100,tx=-100,ty=-100;document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});(function anim(){tx+=(mx-tx)*0.12;ty+=(my-ty)*0.12;trail.style.left=tx+'px';trail.style.top=ty+'px';requestAnimationFrame(anim);})();document.addEventListener('mouseover',e=>{if(e.target.closest('a,button,input,select,textarea,.cw-card'))document.body.classList.add('cursor-hover');});document.addEventListener('mouseout',e=>{if(e.target.closest('a,button,input,select,textarea,.cw-card'))document.body.classList.remove('cursor-hover');});document.addEventListener('mouseleave',()=>{cursor.style.opacity='0';trail.style.opacity='0';});document.addEventListener('mouseenter',()=>{cursor.style.opacity='1';trail.style.opacity='1';});}
  const pt=document.getElementById('page-transition');
  if(pt){document.addEventListener('click',e=>{const link=e.target.closest('a[href]');if(!link)return;const href=link.getAttribute('href');if(!href||href.startsWith('#')||href.startsWith('mailto')||link.target==='_blank')return;if(href.startsWith('http')&&!href.includes(window.location.hostname))return;e.preventDefault();pt.classList.add('enter');setTimeout(()=>window.location.href=href,400);});window.addEventListener('pageshow',()=>{pt.classList.remove('enter');pt.classList.add('exit');setTimeout(()=>pt.classList.remove('exit'),440);});}
  <% if user_signed_in? && current_user.client? %>
  const saved=localStorage.getItem('loov_last_coords');
  const up=new URLSearchParams(window.location.search);
  if(!up.has('latitude')){if(saved){try{const coords=JSON.parse(saved);const url=new URL(window.location);url.searchParams.set('latitude',coords.lat);url.searchParams.set('longitude',coords.lng);window.location.href=url.toString();}catch(e){localStorage.removeItem('loov_last_coords');}}else if(navigator.geolocation){navigator.geolocation.getCurrentPosition(pos=>{localStorage.setItem('loov_last_coords',JSON.stringify({lat:pos.coords.latitude,lng:pos.coords.longitude}));const url=new URL(window.location);url.searchParams.set('latitude',pos.coords.latitude);url.searchParams.set('longitude',pos.coords.longitude);window.location.href=url.toString();},()=>{},{enableHighAccuracy:false,timeout:10000,maximumAge:300000});}}
  <% end %>
})();
function requestGeo(){if(!navigator.geolocation)return;navigator.geolocation.getCurrentPosition(function(pos){localStorage.setItem('loov_last_coords',JSON.stringify({lat:pos.coords.latitude,lng:pos.coords.longitude}));var url=new URL(window.location.href);url.searchParams.set('latitude',pos.coords.latitude);url.searchParams.set('longitude',pos.coords.longitude);window.location.href=url.toString();},function(){alert('Não foi possível obter sua localização.');},{enableHighAccuracy:true,timeout:10000});}
</script>

<% end %>
