      <div class="geo-banner"><p class="geo-banner-text"><i class="fas fa-location-dot" style="color:var(--lime);margin-right:.35rem;"></i>Permita sua localização para ver vagas disponíveis agora.</p><button class="geo-banner-btn" onclick="requestGeo()">Usar localização</button></div>
    <% elsif @disponivel_slots.any? %>
