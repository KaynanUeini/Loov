<% if user_signed_in? && (current_user.owner? || current_user.attendant?) %>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --lime:#afff2d; --lime-dim:#8fcc24;
    --black:#000; --surface:#0a0a0a; --surface-2:#0d0d0d; --surface-3:#131313;
    --border:#1a1a1a; --border-soft:#222;
    --text-muted:#444; --white:#fff;
    --orange:#f97316; --yellow:#fbbf24; --red:#f87171; --blue:#60a5fa;
  }
  body { background:var(--black); font-family:'DM Sans',sans-serif; color:var(--white); overflow-x:hidden; }

  .owner-wrap { display:flex; min-height:100vh; padding-top:60px; }

  .owner-sidebar {
    width:220px; flex-shrink:0;
    background:var(--surface-2); border-right:1px solid var(--border);
    position:fixed; top:60px; bottom:0; left:0;
    display:flex; flex-direction:column; padding:1.25rem 0; z-index:10;
  }
  .sidebar-brand { padding:0 1.25rem 1.25rem; border-bottom:1px solid var(--border); margin-bottom:.75rem; }
  .sidebar-cw-name { font-family:'Bebas Neue',sans-serif; font-size:1.1rem; color:var(--white); letter-spacing:.04em; line-height:1.1; }
  .sidebar-cw-role { font-size:.58rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:rgba(175,255,45,.35); margin-top:2px; }

  .sidebar-nav { display:flex; flex-direction:column; gap:2px; padding:0 .75rem; flex:1; }
  .snav-item { display:flex; align-items:center; gap:.625rem; padding:.625rem .875rem; border-radius:10px; font-size:.8125rem; font-weight:500; color:var(--text-muted); text-decoration:none; transition:all .15s; border:1px solid transparent; background:transparent; cursor:pointer; width:100%; text-align:left; }
  .snav-item:hover { color:var(--white); background:rgba(255,255,255,.03); }
  .snav-item i { width:16px; text-align:center; font-size:.75rem; }
  .snav-badge { margin-left:auto; border-radius:100px; padding:1px 6px; font-size:.52rem; font-weight:800; display:none; }
  .snav-badge.visible { display:inline-block; }
  .snav-badge.yellow { background:var(--yellow); color:#000; }
  .snav-badge.orange { background:var(--orange); color:#000; }

  .sidebar-footer { padding:.75rem 1.25rem 0; border-top:1px solid var(--border); margin-top:auto; }
  .sidebar-date-small { font-size:.62rem; color:var(--text-muted); text-transform:capitalize; }

  .owner-content { margin-left:220px; flex:1; padding:2rem; }

  .owner-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem; gap:1rem; flex-wrap:wrap; }
  .owner-clock-wrap { display:flex; align-items:baseline; gap:.75rem; }
  .owner-clock { font-family:'Bebas Neue',sans-serif; font-size:3.5rem; line-height:1; letter-spacing:.04em; color:var(--white); }
  .owner-date { font-size:.75rem; color:var(--text-muted); text-transform:capitalize; }
  .owner-header-actions { display:flex; align-items:center; gap:.5rem; }

  .hdr-btn { position:relative; width:36px; height:36px; border-radius:10px; background:transparent; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; color:var(--text-muted); font-size:.78rem; cursor:pointer; transition:all .2s; }
  .hdr-btn:hover { color:var(--white); border-color:var(--border-soft); background:rgba(255,255,255,.03); }
  .hdr-btn.has-pending-approvals { border-color:rgba(251,191,36,.3); color:#fbbf24; background:rgba(251,191,36,.04); }
  .hdr-badge { position:absolute; top:-5px; right:-5px; font-family:'Montserrat',sans-serif; font-size:.48rem; font-weight:800; width:15px; height:15px; border-radius:50%; display:none; align-items:center; justify-content:center; border:2px solid #000; }
  .hdr-badge.visible { display:flex; }
  .hdr-badge.yellow { background:var(--yellow); color:#000; }
  .hdr-badge.orange { background:var(--orange); color:#000; }

  .hdr-walkin-btn { background:var(--lime); border:none; border-radius:10px; color:#000; height:36px; padding:0 1rem; font-family:'DM Sans',sans-serif; font-size:.78rem; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:.4rem; transition:background .15s; }
  .hdr-walkin-btn:hover { background:var(--lime-dim); }

  .kpi-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:2rem; }
  .kpi-card { background:var(--surface-2); border:1px solid var(--border); border-radius:16px; padding:1.25rem 1.5rem; position:relative; overflow:hidden; }
  .kpi-card::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(to right,transparent,rgba(175,255,45,.15),transparent); }
  .kpi-label { font-size:.6rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--text-muted); margin-bottom:.5rem; }
  .kpi-value { font-family:'Bebas Neue',sans-serif; font-size:2.25rem; line-height:1; letter-spacing:.02em; color:var(--white); }
  .kpi-value.lime { color:var(--lime); }
  .kpi-value.yellow { color:var(--yellow); }
  .kpi-value.green { color:var(--lime); }
  .kpi-sub { font-size:.68rem; color:var(--text-muted); margin-top:.375rem; }

  .section-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem; }
  .section-title { font-size:.75rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--text-muted); }
  .section-count { font-size:.72rem; color:var(--text-muted); }

  .appts-wrap { background:var(--surface-2); border:1px solid var(--border); border-radius:16px; overflow:hidden; }
  .appts-loading { display:flex; align-items:center; justify-content:center; padding:3rem; gap:.75rem; color:var(--text-muted); font-size:.8125rem; }
  .loov-loader { display:inline-flex; align-items:center; gap:5px; }
  .loov-loader span { width:5px; height:5px; background:var(--lime); border-radius:50%; animation:loaderPulse 1.2s ease-in-out infinite; }
  .loov-loader span:nth-child(2){animation-delay:.2s;} .loov-loader span:nth-child(3){animation-delay:.4s;}
  @keyframes loaderPulse{0%,100%{opacity:.2;transform:scale(.8)}50%{opacity:1;transform:scale(1.2)}}

  .appt-row { display:flex; align-items:center; gap:12px; padding:.875rem 1.25rem; border-bottom:1px solid rgba(255,255,255,.03); transition:background .15s; position:relative; overflow:hidden; }
  .appt-row::before { content:''; position:absolute; left:0; top:6px; bottom:6px; width:2px; border-radius:99px; opacity:0; transition:opacity .2s; }
  .appt-row:hover { background:rgba(255,255,255,.02); }
  .appt-row:hover::before { opacity:1; }
  .appt-row.status-confirmed::before { background:var(--yellow); }
  .appt-row.status-attended::before  { background:var(--lime); }
  .appt-row.status-no_show::before   { background:var(--red); }
  .appt-row.is-attended { opacity:.45; }
  .appt-row.is-no_show  { opacity:.22; }
  .appt-row:last-child { border-bottom:none; }
  .appt-row.flash-green { background:rgba(175,255,45,.06)!important; }
  .appt-row.flash-red   { background:rgba(248,113,113,.06)!important; }

  .appt-info { flex:1; min-width:0; }
  .appt-client { font-size:.8125rem; font-weight:500; color:#e0e0e0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; display:flex; align-items:center; gap:5px; }
  .appt-service { font-size:.7rem; color:#2a2a2a; margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .appt-walkin-tag { font-size:.52rem; color:#444; background:#0a0a0a; border:1px solid #1a1a1a; border-radius:4px; padding:1px 5px; flex-shrink:0; }
  .disp-tag { display:inline-flex; align-items:center; gap:.2rem; background:rgba(175,255,45,.1); border:1px solid rgba(175,255,45,.25); border-radius:100px; padding:.1rem .4rem; font-size:.52rem; font-weight:700; color:var(--lime); flex-shrink:0; }
  .appt-dot { width:4px; height:4px; border-radius:50%; flex-shrink:0; }
  .appt-dot.yellow{background:var(--yellow);} .appt-dot.green{background:var(--lime);} .appt-dot.red{background:var(--red);} .appt-dot.gray{background:#333;}
  .appt-price { font-family:'Bebas Neue',sans-serif; font-size:1rem; color:#333; flex-shrink:0; letter-spacing:.02em; }
  .appt-price.overridden { color:var(--yellow); }

  .appt-actions { display:flex; gap:3px; flex-shrink:0; }
  .appt-btn { width:28px; height:28px; border-radius:8px; border:1px solid rgba(255,255,255,.05); background:transparent; color:#2a2a2a; font-size:.65rem; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all .15s; flex-shrink:0; }
  .appt-btn:hover.attend-btn { background:rgba(175,255,45,.1); border-color:var(--lime); color:var(--lime); }
  .appt-btn:hover.noshow-btn { background:rgba(248,113,113,.1); border-color:var(--red); color:var(--red); }
  .appt-btn:hover.revert-btn { background:rgba(251,191,36,.1); border-color:var(--yellow); color:var(--yellow); }
  .appt-btn:hover.edit-btn   { background:rgba(255,255,255,.04); border-color:#2a2a2a; color:#777; }

  .appts-empty { padding:3rem 1.25rem; text-align:center; }
  .appts-empty-icon { width:48px; height:48px; border-radius:14px; background:rgba(255,255,255,.02); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; margin:0 auto .75rem; font-size:1.1rem; color:#1a1a1a; }
  .appts-empty-title { font-size:.72rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#1e1e1e; margin-bottom:4px; }
  .appts-empty-sub { font-size:.7rem; color:#161616; }

  .upcoming-bar { display:flex; align-items:center; justify-content:space-between; padding:.875rem 1.25rem; border-top:1px solid var(--border); font-size:.72rem; color:var(--text-muted); }
  .upcoming-val { color:rgba(175,255,45,.7); font-weight:700; }

  /* Drawers */
  .drawer-overlay { position:fixed; inset:0; z-index:50; background:rgba(0,0,0,.75); backdrop-filter:blur(8px); opacity:0; pointer-events:none; transition:opacity .25s ease; }
  .drawer-overlay.open { opacity:1; pointer-events:all; }
  .side-drawer { position:fixed; top:0; right:0; bottom:0; z-index:51; width:min(400px,94vw); background:rgba(3,3,3,0.98); display:flex; flex-direction:column; transform:translateX(100%); transition:transform .32s cubic-bezier(.32,.72,0,1); box-shadow:-20px 0 60px rgba(0,0,0,.7); }
  .side-drawer.open { transform:translateX(0); }
  .drawer-hdr { padding:20px; border-bottom:1px solid rgba(255,255,255,.04); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .drawer-title { font-family:'Montserrat',sans-serif; font-size:.62rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase; display:flex; align-items:center; gap:8px; }
  .drawer-title.yellow { color:var(--yellow); border-left:2px solid var(--yellow); padding-left:10px; }
  .drawer-title.orange { color:var(--orange); border-left:2px solid var(--orange); padding-left:10px; }
  .drawer-title-badge { border-radius:100px; font-size:.56rem; font-weight:800; padding:2px 7px; }
  .drawer-title.yellow .drawer-title-badge { background:var(--yellow); color:#000; }
  .drawer-title.orange .drawer-title-badge { background:var(--orange); color:#000; }
  .drawer-close { background:none; border:1px solid rgba(255,255,255,.06); border-radius:8px; width:30px; height:30px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#444; font-size:.75rem; transition:all .15s; }
  .drawer-close:hover { border-color:var(--red); color:var(--red); }
  .drawer-body { overflow-y:auto; flex:1; padding:12px; }
  .drawer-body::-webkit-scrollbar { width:2px; }
  .drawer-body::-webkit-scrollbar-thumb { background:#1a1a1a; border-radius:99px; }
  .drawer-empty { padding:32px 16px; text-align:center; color:#222; font-size:.75rem; }

  .approval-card { background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.05); border-radius:12px; padding:12px 14px; margin-bottom:8px; transition:opacity .2s,transform .2s; position:relative; overflow:hidden; }
  .approval-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:2px; background:var(--yellow); opacity:.5; }
  .approval-card.removing { opacity:0; transform:translateX(16px); }
  .approval-card-header { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:6px; }
  .approval-card-desc { font-size:.78rem; color:#e0e0e0; line-height:1.4; flex:1; }
  .approval-card-meta { font-size:.62rem; color:#333; margin-bottom:8px; }
  .approval-toggle { background:rgba(251,191,36,.08); border:1px solid rgba(251,191,36,.15); color:var(--yellow); border-radius:6px; width:22px; height:22px; font-size:.6rem; cursor:pointer; flex-shrink:0; display:flex; align-items:center; justify-content:center; transition:background .15s; }
  .approval-toggle:hover { background:rgba(251,191,36,.15); }
  .approval-detail { display:none; background:rgba(0,0,0,.5); border:1px solid rgba(255,255,255,.04); border-radius:8px; padding:10px; margin-bottom:8px; font-size:.7rem; line-height:1.6; }
  .approval-actions { display:flex; gap:6px; }
  .btn-approve { flex:1; background:rgba(175,255,45,.08); border:1px solid rgba(175,255,45,.2); color:var(--lime); border-radius:7px; font-size:.68rem; font-weight:700; cursor:pointer; padding:6px 0; transition:all .15s; }
  .btn-approve:hover { background:rgba(175,255,45,.14); border-color:var(--lime); }
  .btn-reject { flex:1; background:rgba(248,113,113,.06); border:1px solid rgba(248,113,113,.15); color:var(--red); border-radius:7px; font-size:.68rem; font-weight:700; cursor:pointer; padding:6px 0; transition:all .15s; }
  .btn-reject:hover { background:rgba(248,113,113,.12); border-color:var(--red); }

  .pending-day-group { margin-bottom:16px; }
  .pending-day-label { font-family:'Montserrat',sans-serif; font-size:.55rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:rgba(249,115,22,.5); padding:0 4px 6px; border-bottom:1px solid rgba(249,115,22,.08); margin-bottom:8px; }
  .pending-appt-card { display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:12px; margin-bottom:4px; border:1px solid rgba(249,115,22,.08); background:rgba(249,115,22,.02); position:relative; overflow:hidden; transition:opacity .2s,transform .2s; }
  .pending-appt-card::before { content:''; position:absolute; left:0; top:4px; bottom:4px; width:2px; background:var(--orange); border-radius:99px; opacity:.5; }
  .pending-appt-card.removing { opacity:0; transform:translateX(16px); }
  .pending-appt-time { font-family:'Bebas Neue',sans-serif; font-size:1.1rem; color:var(--orange); line-height:1; letter-spacing:.02em; flex-shrink:0; min-width:40px; text-align:center; }
  .pending-appt-info { flex:1; min-width:0; }
  .pending-appt-client { font-size:.8rem; font-weight:500; color:#e0e0e0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .pending-appt-service { font-size:.68rem; color:#333; margin-top:1px; }
  .pending-appt-price { font-family:'Bebas Neue',sans-serif; font-size:.9rem; color:#444; flex-shrink:0; }
  .pending-appt-actions { display:flex; gap:4px; flex-shrink:0; }
  .pending-btn-attend { background:rgba(175,255,45,.08); border:1px solid rgba(175,255,45,.2); color:var(--lime); border-radius:7px; font-size:.62rem; font-weight:700; cursor:pointer; padding:5px 8px; transition:all .15s; white-space:nowrap; }
  .pending-btn-attend:hover { background:rgba(175,255,45,.15); border-color:var(--lime); }
  .pending-btn-noshow { background:rgba(248,113,113,.06); border:1px solid rgba(248,113,113,.15); color:var(--red); border-radius:7px; font-size:.62rem; font-weight:700; cursor:pointer; padding:5px 8px; transition:all .15s; white-space:nowrap; }
  .pending-btn-noshow:hover { background:rgba(248,113,113,.12); border-color:var(--red); }

  .toast-container { position:fixed; bottom:28px; left:50%; transform:translateX(-50%); z-index:300; display:flex; flex-direction:column; align-items:center; gap:8px; pointer-events:none; }
  .toast { display:inline-flex; align-items:center; gap:8px; padding:10px 18px; border-radius:100px; font-family:'Montserrat',sans-serif; font-size:.7rem; font-weight:600; backdrop-filter:blur(16px); box-shadow:0 8px 24px rgba(0,0,0,.5); opacity:0; transform:translateY(12px); animation:toastIn .3s ease forwards; pointer-events:none; }
  .toast.success { background:rgba(175,255,45,.12); border:1px solid rgba(175,255,45,.3); color:var(--lime); }
  .toast.error   { background:rgba(248,113,113,.12); border:1px solid rgba(248,113,113,.3); color:var(--red); }
  .toast.warning { background:rgba(249,115,22,.12); border:1px solid rgba(249,115,22,.3); color:var(--orange); }
  .toast.out { animation:toastOut .3s ease forwards; }
  @keyframes toastIn  { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
  @keyframes toastOut { from{opacity:1;transform:translateY(0)} to{opacity:0;transform:translateY(-8px)} }
  @keyframes spin { to{transform:rotate(360deg)} }
  .spin { animation:spin .8s linear infinite; display:inline-block; }

  @media(max-width:900px) { .owner-sidebar{display:none;} .owner-content{margin-left:0;} .kpi-grid{grid-template-columns:repeat(2,1fr);} }
  @media(max-width:600px) { .owner-content{padding:1rem;} .kpi-grid{grid-template-columns:1fr 1fr;} }
</style>

<div class="drawer-overlay" id="approval-overlay"></div>
<div class="side-drawer" id="approval-drawer">
  <div class="drawer-hdr">
    <div class="drawer-title yellow"><i class="fas fa-clock"></i>Aprovações pendentes<span class="drawer-title-badge" id="drawer-badge">0</span></div>
    <button class="drawer-close" id="drawer-close"><i class="fas fa-xmark"></i></button>
  </div>
  <div class="drawer-body" id="drawer-body">
    <div class="drawer-empty"><i class="fas fa-check-circle" style="display:block;font-size:1.5rem;margin-bottom:8px;color:#1a1a1a;"></i>Nenhuma alteração pendente.</div>
  </div>
</div>

<div class="drawer-overlay" id="pending-overlay"></div>
<div class="side-drawer" id="pending-drawer">
  <div class="drawer-hdr">
    <div class="drawer-title orange"><i class="fas fa-triangle-exclamation"></i>Dias anteriores<span class="drawer-title-badge" id="pending-drawer-badge">0</span></div>
    <button class="drawer-close" id="pending-drawer-close"><i class="fas fa-xmark"></i></button>
  </div>
  <div class="drawer-body" id="pending-drawer-body">
    <div class="drawer-empty">Carregando...</div>
  </div>
</div>

<div class="toast-container" id="toast-container"></div>

<div class="owner-wrap">
  <aside class="owner-sidebar">
    <div class="sidebar-brand">
      <div class="sidebar-cw-name"><%= @car_wash&.name&.upcase || "LOOV" %></div>
      <div class="sidebar-cw-role"><%= current_user.owner? ? "Proprietário" : "Atendente" %></div>
    </div>
    <nav class="sidebar-nav">
      <% if current_user.owner? %>
      <%= link_to manage_car_wash_path(@car_wash), class: "snav-item" do %><i class="fas fa-store"></i> Meu Negócio<% end %>
      <%= link_to owner_car_wash_appointments_path, class: "snav-item" do %><i class="fas fa-calendar-days"></i> Agenda<% end %>
      <%= link_to owner_monthly_costs_path, class: "snav-item" do %><i class="fas fa-wallet"></i> Financeiro<% end %>
      <%= link_to owner_financial_tracking_path, class: "snav-item" do %><i class="fas fa-chart-line"></i> Relatórios<% end %>
      <%= link_to owner_ai_insights_path, class: "snav-item" do %><i class="fas fa-brain"></i> IA Insights<% end %>
      <%= link_to owner_attendant_invitations_path, class: "snav-item" do %><i class="fas fa-users"></i> Equipe<% end %>
      <% else %>
      <% _cw = current_car_wash %>
      <% if _cw %>
      <%= link_to manage_car_wash_path(_cw), class: "snav-item" do %><i class="fas fa-store"></i> Meu Negócio<% end %>
      <% end %>
      <% end %>
      <% if current_user.owner? %>
      <button class="snav-item" id="approval-nav-btn" style="display:none;" onclick="openApprovalDrawer()">
        <i class="fas fa-bell"></i> Aprovações
        <span class="snav-badge yellow" id="snav-approval-badge"></span>
      </button>
      <% end %>
      <button class="snav-item" id="pending-nav-btn" style="display:none;" onclick="openPendingDrawer()">
        <i class="fas fa-triangle-exclamation"></i> Pendências
        <span class="snav-badge orange" id="snav-pending-badge"></span>
      </button>
    </nav>
    <div class="sidebar-footer">
      <div class="sidebar-date-small" id="sidebar-date-small"></div>
    </div>
  </aside>

  <main class="owner-content">
    <div class="owner-header">
      <div class="owner-clock-wrap">
        <div class="owner-clock" id="owner-clock">00:00</div>
        <div class="owner-date" id="owner-date"></div>
      </div>
      <div class="owner-header-actions">
        <button class="hdr-btn" id="pending-hdr-btn" title="Pendências de dias anteriores" onclick="openPendingDrawer()" style="display:none;">
          <i class="fas fa-triangle-exclamation"></i>
          <span class="hdr-badge orange" id="pending-hdr-badge"></span>
        </button>
        <% if current_user.owner? %>
        <button class="hdr-btn" id="approval-hdr-btn" title="Aprovações pendentes" onclick="openApprovalDrawer()">
          <i class="fas fa-bell"></i>
          <span class="hdr-badge yellow" id="approval-hdr-badge"></span>
        </button>
        <% end %>
        <button class="hdr-walkin-btn" id="btn-walk-in"><i class="fas fa-plus"></i> Avulso</button>
      </div>
    </div>

    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-label">Caixa do dia</div>
        <div class="kpi-value lime" id="kpi-revenue">R$&nbsp;<%= number_with_precision(@today_revenue || 0, precision: 0, delimiter: '.') %></div>
        <div class="kpi-sub" id="kpi-revenue-sub">vs. média 7 dias</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Total</div>
        <div class="kpi-value" id="kpi-total"><%= @today_total || 0 %></div>
        <div class="kpi-sub">agendamentos hoje</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Aguardando</div>
        <div class="kpi-value yellow" id="kpi-pending"><%= @today_pending || 0 %></div>
        <div class="kpi-sub">confirmados hoje</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Vieram</div>
        <div class="kpi-value green" id="kpi-attended"><%= @today_attended || 0 %></div>
        <div class="kpi-sub">atendidos hoje</div>
      </div>
    </div>

    <div class="section-header">
      <span class="section-title">Agenda de Hoje</span>
      <span class="section-count" id="agenda-count">—</span>
    </div>
    <div class="appts-wrap">
      <div id="appts-list">
        <div class="appts-loading"><div class="loov-loader"><span></span><span></span><span></span></div> Carregando agenda...</div>
      </div>
      <div class="upcoming-bar">
        <span>Próximos 7 dias: <span class="upcoming-val"><%= @upcoming_count || 0 %> agend.</span></span>
        <% if current_user.owner? %>
        <%= link_to owner_car_wash_appointments_path, style: "font-size:.72rem;color:rgba(175,255,45,.5);text-decoration:none;" do %>Ver agenda completa <i class="fas fa-arrow-right" style="font-size:.6rem;"></i><% end %>
        <% end %>
      </div>
    </div>
  </main>
</div>

<%= render 'owner/disponivel_acceptance/widget' %>

<script>
(function() {
  const CSRF = document.querySelector('meta[name="csrf-token"]')?.content;
  let allServices = [];

  function updateClock() {
    const now = new Date();
    const hh = String(now.getHours()).padStart(2,'0');
    const mm = String(now.getMinutes()).padStart(2,'0');
    const dateStr = now.toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long'});
    document.getElementById('owner-clock').textContent = hh + ':' + mm;
    document.getElementById('owner-date').textContent  = dateStr;
    document.getElementById('sidebar-date-small').textContent = dateStr;
  }
  updateClock(); setInterval(updateClock, 1000);

  function showToast(msg, type='success') {
    const c=document.getElementById('toast-container'), t=document.createElement('div');
    t.className=`toast ${type}`;
    const icons={success:'fa-check',error:'fa-times',warning:'fa-triangle-exclamation'};
    t.innerHTML=`<i class="fas ${icons[type]||'fa-check'}"></i> ${msg}`;
    c.appendChild(t);
    setTimeout(()=>{t.classList.add('out');setTimeout(()=>t.remove(),320);},3500);
  }

  function animateCounter(el, target, isRev, dur=500) {
    if (!el) return;
    const st=performance.now();
    function ease(t){return 1-Math.pow(1-t,3);}
    function step(ct){const p=Math.min((ct-st)/dur,1),v=Math.round(ease(p)*target);el.textContent=isRev?'R$\u00A0'+v.toLocaleString('pt-BR'):v;if(p<1)requestAnimationFrame(step);}
    requestAnimationFrame(step);
  }

  async function patch(url, body={}) {
    const r=await fetch(url,{method:'PATCH',headers:{'X-CSRF-Token':CSRF,'Content-Type':'application/json'},body:JSON.stringify(body)});
    return r.json();
  }
  async function post(url, body={}) {
    const r=await fetch(url,{method:'POST',headers:{'X-CSRF-Token':CSRF,'Content-Type':'application/json'},body:JSON.stringify(body)});
    return r.json();
  }

  function showEditModal(a) {
    document.getElementById('edit-modal')?.remove();
    const modal=document.createElement('div');
    modal.id='edit-modal';
    modal.style.cssText='position:fixed;inset:0;z-index:100;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.9);backdrop-filter:blur(8px);padding:24px;';
    const opts=allServices.map(s=>`<option value="${s.id}" ${s.id===a.service_id?'selected':''}>${s.title} \u2014 R$ ${s.price.toFixed(0)}</option>`).join('');
    modal.innerHTML=`<div style="background:#080808;border:1px solid #1e1e1e;border-radius:20px;padding:24px;width:100%;max-width:360px;font-family:'Montserrat',sans-serif;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;"><span style="font-size:.65rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#afff2d;">Editar Serviço</span><button id="edit-close" style="background:none;border:none;color:#444;font-size:1rem;cursor:pointer;"><i class="fas fa-xmark"></i></button></div>
      <div style="font-size:.75rem;color:#555;margin-bottom:16px;">${a.client} · ${a.time}</div>
      <label style="font-size:.6rem;color:#444;text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:6px;">Serviço</label>
      <select id="edit-service" style="width:100%;background:#111;border:1px solid #1e1e1e;border-radius:8px;color:#fff;padding:10px 12px;font-size:.82rem;margin-bottom:14px;outline:none;">${opts}</select>
      <label style="font-size:.6rem;color:#444;text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:6px;">Valor (vazio = padrão)</label>
      <input id="edit-price" type="number" step="0.01" min="0" placeholder="R$ ${a.price.toFixed(2)}" value="${a.price_overridden?a.price.toFixed(2):''}" style="width:100%;background:#111;border:1px solid #1e1e1e;border-radius:8px;color:#fff;padding:10px 12px;font-size:.82rem;margin-bottom:20px;outline:none;">
      <div style="display:flex;gap:8px;"><button id="edit-cancel" style="flex:1;background:transparent;border:1px solid #1e1e1e;border-radius:8px;color:#444;padding:10px;font-size:.8rem;cursor:pointer;">Cancelar</button><button id="edit-save" style="flex:2;background:#afff2d;border:none;border-radius:8px;color:#000;padding:10px;font-size:.8rem;font-weight:700;cursor:pointer;">Salvar</button></div>
    </div>`;
    document.body.appendChild(modal);
    modal.querySelector('#edit-close').addEventListener('click',()=>modal.remove());
    modal.querySelector('#edit-cancel').addEventListener('click',()=>modal.remove());
    modal.querySelector('#edit-save').addEventListener('click', async()=>{
      const btn=modal.querySelector('#edit-save'); btn.textContent='...'; btn.disabled=true;
      const data=await patch(`/owner/checkins/${a.id}/update_service`,{service_id:modal.querySelector('#edit-service').value,price_override:modal.querySelector('#edit-price').value.trim()||null});
      modal.remove(); if(data.ok) loadToday();
    });
  }

  function showWalkInModal() {
    document.getElementById('walkin-modal')?.remove();
    const modal=document.createElement('div');
    modal.id='walkin-modal';
    modal.style.cssText='position:fixed;inset:0;z-index:100;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.9);backdrop-filter:blur(8px);padding:24px;';
    const opts=allServices.map(s=>`<option value="${s.id}">${s.title} \u2014 R$ ${s.price.toFixed(0)}</option>`).join('');
    const nowTime=new Date().toTimeString().slice(0,5);
    modal.innerHTML=`<div style="background:#080808;border:1px solid #1e1e1e;border-radius:20px;padding:24px;width:100%;max-width:360px;font-family:'Montserrat',sans-serif;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;"><span style="font-size:.65rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#afff2d;">+ Serviço Avulso</span><button id="wi-close" style="background:none;border:none;color:#444;font-size:1rem;cursor:pointer;"><i class="fas fa-xmark"></i></button></div>
      <label style="font-size:.6rem;color:#444;text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:6px;">Cliente</label>
      <input id="wi-name" type="text" placeholder="Nome do cliente" style="width:100%;background:#111;border:1px solid #1e1e1e;border-radius:8px;color:#fff;padding:10px 12px;font-size:.82rem;margin-bottom:12px;outline:none;">
      <label style="font-size:.6rem;color:#444;text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:6px;">Horário</label>
      <input id="wi-time" type="time" value="${nowTime}" style="width:100%;background:#111;border:1px solid #1e1e1e;border-radius:8px;color:#fff;padding:10px 12px;font-size:.82rem;margin-bottom:12px;outline:none;">
      <label style="font-size:.6rem;color:#444;text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:6px;">Serviço</label>
      <select id="wi-service" style="width:100%;background:#111;border:1px solid #1e1e1e;border-radius:8px;color:#fff;padding:10px 12px;font-size:.82rem;margin-bottom:12px;outline:none;">${opts}</select>
      <label style="font-size:.6rem;color:#444;text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:6px;">Valor (opcional)</label>
      <input id="wi-price" type="number" step="0.01" min="0" placeholder="Usa o preço do serviço" style="width:100%;background:#111;border:1px solid #1e1e1e;border-radius:8px;color:#fff;padding:10px 12px;font-size:.82rem;margin-bottom:18px;outline:none;">
      <div id="wi-error" style="color:#f87171;font-size:.7rem;margin-bottom:10px;display:none;"></div>
      <div style="display:flex;gap:8px;"><button id="wi-cancel" style="flex:1;background:transparent;border:1px solid #1e1e1e;border-radius:8px;color:#444;padding:10px;font-size:.8rem;cursor:pointer;">Cancelar</button><button id="wi-save" style="flex:2;background:#afff2d;border:none;border-radius:8px;color:#000;padding:10px;font-size:.8rem;font-weight:700;cursor:pointer;">Registrar</button></div>
    </div>`;
    document.body.appendChild(modal);
    modal.querySelector('#wi-close').addEventListener('click',()=>modal.remove());
    modal.querySelector('#wi-cancel').addEventListener('click',()=>modal.remove());
    modal.querySelector('#wi-save').addEventListener('click', async()=>{
      const name=modal.querySelector('#wi-name').value.trim(),errEl=modal.querySelector('#wi-error'),btn=modal.querySelector('#wi-save');
      if(!name){errEl.textContent='Informe o nome do cliente.';errEl.style.display='block';return;}
      errEl.style.display='none'; btn.textContent='...'; btn.disabled=true;
      const data=await post('/owner/checkins/walk_in',{walk_in_name:name,scheduled_at:modal.querySelector('#wi-time').value,service_id:modal.querySelector('#wi-service').value,price_override:modal.querySelector('#wi-price').value.trim()||null});
      if(data.ok){modal.remove();loadToday();}
      else{errEl.textContent=data.error||'Erro ao registrar.';errEl.style.display='block';btn.textContent='Registrar';btn.disabled=false;}
    });
  }

  function renderRow(a) {
    const settled = a.status==='attended' || a.status==='no_show';
    let metaHtml = '';
    if (a.phone_last4 || a.vehicle) {
      const parts = [];
      if (a.phone_last4) parts.push(
        `<span style="display:inline-flex;align-items:center;gap:.25rem;">` +
        `<span style="font-size:.55rem;color:#2a2a2a;text-transform:uppercase;letter-spacing:.1em;font-weight:700;">código</span>` +
        `<span style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#afff2d;letter-spacing:.08em;">${a.phone_last4}</span>` +
        `</span>`
      );
      if (a.vehicle) parts.push(`<span style="font-size:.65rem;color:#444;">${a.vehicle}</span>`);
      metaHtml = `<div style="display:flex;align-items:center;gap:.5rem;margin-top:3px;">${parts.join('')}</div>`;
    }
    const dispBadge = a.is_disponivel ? `<span class="disp-tag"><i class="fas fa-bolt"></i>Disp.</span>` : '';
    let priceHtml;
    if (a.is_disponivel && a.remaining_amount != null) {
      priceHtml = `<span class="appt-price" style="color:var(--lime);">R$${a.remaining_amount.toFixed(0)}</span>`;
    } else {
      priceHtml = `<span class="appt-price ${a.price_overridden?'overridden':''}">R$${a.price.toFixed(0)}</span>`;
    }
    const row = document.createElement('div');
    row.className = `appt-row status-${a.status}${a.status==='attended'?' is-attended':a.status==='no_show'?' is-no_show':''}`;
    row.dataset.id = a.id;
    row.innerHTML = `
      <div style="display:flex;flex-direction:column;align-items:center;flex-shrink:0;min-width:56px;gap:2px;">
        <span style="font-family:'Bebas Neue',sans-serif;font-size:1.75rem;color:var(--white);line-height:1;letter-spacing:.02em;">${a.time}</span>
        <span class="appt-dot ${a.status_color}"></span>
      </div>
      <div class="appt-info">
        <div class="appt-client">${a.client}${dispBadge}${a.walk_in?'<span class="appt-walkin-tag">avulso</span>':''}</div>
        <div class="appt-service">${a.service}</div>
        ${metaHtml}
      </div>
      ${priceHtml}
      <div class="appt-actions">
        <button class="appt-btn edit-btn" data-action="edit" title="Editar serviço"><i class="fas fa-pen"></i></button>
        ${settled
          ? `<button class="appt-btn revert-btn" data-action="revert" title="Desfazer"><i class="fas fa-rotate-left"></i></button>`
          : `<button class="appt-btn attend-btn" data-action="attend" title="Compareceu"><i class="fas fa-check"></i></button>
             <button class="appt-btn noshow-btn" data-action="noshow" title="Não veio"><i class="fas fa-xmark"></i></button>`
        }
      </div>`;
    row.querySelectorAll('.appt-btn').forEach(btn=>{
      btn.addEventListener('click', async e=>{
        e.stopPropagation();
        if(btn.dataset.action==='edit'){showEditModal(a);return;}
        btn.disabled=true; btn.innerHTML='<i class="fas fa-circle-notch spin"></i>';
        const urls={attend:`/owner/checkins/${a.id}/attend`,noshow:`/owner/checkins/${a.id}/no_show`,revert:`/owner/checkins/${a.id}/revert`};
        const data=await patch(urls[btn.dataset.action]);
        if(data.ok){
          if(btn.dataset.action==='attend') row.classList.add('flash-green');
          else if(btn.dataset.action==='noshow') row.classList.add('flash-red');
          setTimeout(()=>loadToday(),420);
        }
      });
    });
    return row;
  }

  async function loadToday() {
    const res = await fetch('/owner/checkins/today',{headers:{Accept:'application/json'}});
    const data = await res.json();
    const appts=data.appointments||[], summary=data.summary||{};
    allServices = data.services||[];
    animateCounter(document.getElementById('kpi-total'),    summary.total||0,    false);
    animateCounter(document.getElementById('kpi-pending'),  summary.pending||0,  false);
    animateCounter(document.getElementById('kpi-attended'), summary.attended||0, false);
    animateCounter(document.getElementById('kpi-revenue'),  summary.revenue_today||0, true, 600);
    const avg7=summary.avg_7_days||0, rev=summary.revenue_today||0;
    if (avg7 > 0) {
      const diff=rev-avg7, sign=diff>=0?'+':'';
      document.getElementById('kpi-revenue-sub').textContent=`${sign}R$${Math.abs(diff).toFixed(0)} vs média 7 dias`;
    }
    document.getElementById('agenda-count').textContent = `${appts.length} agendamento${appts.length===1?'':'s'}`;
    const list = document.getElementById('appts-list');
    list.innerHTML = '';
    if (!appts.length) {
      const h=new Date().getHours();
      const sub=h<8?'O movimento começa mais tarde.':h<12?'A manhã ainda está tranquila.':h<18?'Sem agendamentos esta tarde.':'Fim de expediente tranquilo.';
      list.innerHTML=`<div class="appts-empty"><div class="appts-empty-icon"><i class="fas fa-calendar-xmark"></i></div><div class="appts-empty-title">Nenhum agendamento</div><div class="appts-empty-sub">${sub}</div></div>`;
    } else {
      appts.forEach(a => list.appendChild(renderRow(a)));
    }
    updatePendingBadge(data.pending_days||[]);
  }

  function updatePendingBadge(pendingDays) {
    const hdrBtn=document.getElementById('pending-hdr-btn');
    const navBtn=document.getElementById('pending-nav-btn');
    const hdrBadge=document.getElementById('pending-hdr-badge');
    const snavBadge=document.getElementById('snav-pending-badge');
    const drawerBadge=document.getElementById('pending-drawer-badge');
    if (pendingDays.length > 0) {
      if(hdrBtn){hdrBtn.style.display='flex';hdrBadge.textContent=pendingDays.length;hdrBadge.classList.add('visible');}
      if(navBtn){navBtn.style.display='flex';snavBadge.textContent=pendingDays.length;snavBadge.classList.add('visible');}
      if(drawerBadge) drawerBadge.textContent=pendingDays.length;
      if(!hdrBtn?.dataset.notified){if(hdrBtn)hdrBtn.dataset.notified='1';showToast(`${pendingDays.length} agendamento${pendingDays.length>1?'s':''} de dias anteriores aguardando.`,'warning');}
    } else {
      if(hdrBtn) hdrBtn.style.display='none';
      if(navBtn) navBtn.style.display='none';
    }
    if(hdrBtn) hdrBtn.dataset.pendingData = JSON.stringify(pendingDays);
  }

  function renderPendingDrawer(pendingDays) {
    const body=document.getElementById('pending-drawer-body');
    if(!pendingDays.length){body.innerHTML='<div class="drawer-empty"><i class="fas fa-check-circle" style="display:block;font-size:1.5rem;margin-bottom:8px;color:#1a1a1a;"></i>Nenhuma pendência.</div>';return;}
    const grouped={};
    pendingDays.forEach(a=>{const key=a.date||a.scheduled_at?.split('T')[0]||'Sem data';if(!grouped[key])grouped[key]=[];grouped[key].push(a);});
    body.innerHTML='';
    Object.keys(grouped).sort().forEach(date=>{
      const group=document.createElement('div'); group.className='pending-day-group';
      const [y,m,d]=date.split('-');
      const label=d&&m&&y?new Date(y,m-1,d).toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long'}):date;
      group.innerHTML=`<div class="pending-day-label">${label}</div>`;
      grouped[date].forEach(a=>{
        const card=document.createElement('div'); card.className='pending-appt-card'; card.id=`pcard-${a.id}`;
        card.innerHTML=`<div class="pending-appt-time">${a.time}</div><div class="pending-appt-info"><div class="pending-appt-client">${a.client}</div><div class="pending-appt-service">${a.service}</div></div><div class="pending-appt-price">R$${parseFloat(a.price).toFixed(0)}</div><div class="pending-appt-actions"><button class="pending-btn-attend"><i class="fas fa-check"></i> Veio</button><button class="pending-btn-noshow"><i class="fas fa-xmark"></i> Faltou</button></div>`;
        card.querySelector('.pending-btn-attend').addEventListener('click',async function(){await resolvePending(a.id,'attend',this,card);});
        card.querySelector('.pending-btn-noshow').addEventListener('click',async function(){await resolvePending(a.id,'no_show',this,card);});
        group.appendChild(card);
      });
      body.appendChild(group);
    });
  }

  async function resolvePending(id, action, btn, card) {
    btn.disabled=true; btn.innerHTML='<i class="fas fa-circle-notch spin"></i>';
    const url=action==='attend'?`/owner/checkins/${id}/attend`:`/owner/checkins/${id}/no_show`;
    const data=await patch(url);
    if(data.ok){card.classList.add('removing');setTimeout(()=>{card.remove();showToast(action==='attend'?'Marcado como compareceu.':'Marcado como não veio.',action==='attend'?'success':'error');loadToday();},220);}
    else{btn.disabled=false;btn.innerHTML=action==='attend'?'<i class="fas fa-check"></i> Veio':'<i class="fas fa-xmark"></i> Faltou';showToast('Erro ao atualizar.','error');}
  }

  window.openPendingDrawer = function() {
    const btn=document.getElementById('pending-hdr-btn');
    const pendingDays=JSON.parse(btn?.dataset.pendingData||'[]');
    renderPendingDrawer(pendingDays);
    document.getElementById('pending-drawer').classList.add('open');
    document.getElementById('pending-overlay').classList.add('open');
    document.body.style.overflow='hidden';
  };
  function closePendingDrawer() {
    document.getElementById('pending-drawer').classList.remove('open');
    document.getElementById('pending-overlay').classList.remove('open');
    document.body.style.overflow='';
  }

  const costLabels={rent:'Aluguel',salaries:'Salários',utilities:'Energia/Água',products:'Produtos',maintenance:'Manutenção',other_fixed:'Outros fixos',other_variable:'Outros variáveis',notes:'Observações'};
  function formatPayload(ct, payload) {
    if(!payload)return'<em style="color:#333">Sem detalhes.</em>';
    if(ct==='monthly_costs'){const cp=payload.cost_params||{},month=payload.month?`${String(payload.month).padStart(2,'0')}/${payload.year}`:'';let rows=`<div style="font-size:.6rem;color:#fbbf24;margin-bottom:6px;font-weight:700;letter-spacing:.1em;">CUSTOS — ${month}</div>`;rows+=Object.entries(cp).map(([k,v])=>{if(v===''||v===null||v===undefined)return'';const label=costLabels[k]||k;const val=k==='notes'?`<span style="color:#555">${v||'—'}</span>`:`<span style="color:#e0e0e0">R$ ${parseFloat(v).toLocaleString('pt-BR',{minimumFractionDigits:2})}</span>`;return`<div style="display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid #0f0f0f;"><span style="color:#333">${label}</span>${val}</div>`;}).join('');return rows;}
    return`<pre style="font-size:.62rem;color:#444;white-space:pre-wrap;margin:0;">${JSON.stringify(payload,null,2)}</pre>`;
  }
  function toggleDetail(id){const el=document.getElementById(id),icon=document.getElementById('icon-'+id);if(!el)return;const open=el.style.display==='none';el.style.display=open?'block':'none';icon.className=open?'fas fa-minus':'fas fa-plus';}
  window.toggleDetail=toggleDetail;
  function removeCard(cardEl, cb){cardEl.classList.add('removing');setTimeout(cb,220);}

  async function loadApprovals() {
    const btn=document.getElementById('approval-hdr-btn'); if(!btn)return;
    try {
      const res=await fetch('/owner/pending_changes',{headers:{Accept:'application/json'}});
      const data=await res.json();
      const hdrBadge=document.getElementById('approval-hdr-badge');
      const snavBadge=document.getElementById('snav-approval-badge');
      const navBtn=document.getElementById('approval-nav-btn');
      if(data.length>0){btn.classList.add('has-pending-approvals');hdrBadge.textContent=data.length;hdrBadge.classList.add('visible');if(snavBadge){snavBadge.textContent=data.length;snavBadge.classList.add('visible');}if(navBtn)navBtn.style.display='flex';}
      else{btn.classList.remove('has-pending-approvals');hdrBadge.classList.remove('visible');if(navBtn)navBtn.style.display='none';}
      renderApprovalDrawer(data);
    } catch(e) {}
  }

  function renderApprovalDrawer(data) {
    const body=document.getElementById('drawer-body'), badge=document.getElementById('drawer-badge');
    badge.textContent=data.length;
    if(!data.length){body.innerHTML='<div class="drawer-empty"><i class="fas fa-check-circle" style="display:block;font-size:1.5rem;margin-bottom:8px;color:#1a1a1a;"></i>Nenhuma alteração pendente.</div>';return;}
    body.innerHTML='';
    data.forEach(pc=>{
      const did=`detail-${pc.id}`, card=document.createElement('div');
      card.className='approval-card'; card.id=`acard-${pc.id}`;
      card.innerHTML=`<div class="approval-card-header"><div class="approval-card-desc">${pc.description}</div><button class="approval-toggle" onclick="toggleDetail('${did}')"><i class="fas fa-plus" id="icon-${did}"></i></button></div><div class="approval-card-meta"><i class="fas fa-user" style="margin-right:4px;color:#2a2a2a;"></i>${pc.attendant} · ${pc.created_at}</div><div id="${did}" class="approval-detail">${formatPayload(pc.change_type,pc.payload)}</div><div class="approval-actions"><button class="btn-approve" onclick="approveChange(${pc.id},this)"><i class="fas fa-check"></i> Aprovar</button><button class="btn-reject" onclick="rejectChange(${pc.id},this)"><i class="fas fa-times"></i> Rejeitar</button></div>`;
      body.appendChild(card);
    });
  }

  window.approveChange = async function(id, btn) {
    if(btn){btn.disabled=true;btn.innerHTML='<i class="fas fa-circle-notch spin"></i>';}
    try{await fetch(`/owner/pending_changes/${id}/approve`,{method:'PATCH',headers:{'X-CSRF-Token':CSRF,'Content-Type':'application/json'}});const card=document.getElementById(`acard-${id}`);if(card)removeCard(card,()=>loadApprovals());else loadApprovals();showToast('Alteração aprovada.','success');}
    catch(e){showToast('Erro ao aprovar.','error');if(btn){btn.disabled=false;btn.innerHTML='<i class="fas fa-check"></i> Aprovar';}}
  };
  window.rejectChange = async function(id, btn) {
    if(btn){btn.disabled=true;btn.innerHTML='<i class="fas fa-circle-notch spin"></i>';}
    try{await fetch(`/owner/pending_changes/${id}/reject`,{method:'PATCH',headers:{'X-CSRF-Token':CSRF,'Content-Type':'application/json'}});const card=document.getElementById(`acard-${id}`);if(card)removeCard(card,()=>loadApprovals());else loadApprovals();showToast('Alteração rejeitada.','error');}
    catch(e){showToast('Erro ao rejeitar.','error');if(btn){btn.disabled=false;btn.innerHTML='<i class="fas fa-times"></i> Rejeitar';}}
  };

  window.openApprovalDrawer = function() {
    document.getElementById('approval-drawer').classList.add('open');
    document.getElementById('approval-overlay').classList.add('open');
    document.body.style.overflow='hidden';
  };
  function closeApprovalDrawer() {
    document.getElementById('approval-drawer').classList.remove('open');
    document.getElementById('approval-overlay').classList.remove('open');
    document.body.style.overflow='';
  }

  document.getElementById('pending-drawer-close')?.addEventListener('click', closePendingDrawer);
  document.getElementById('pending-overlay')?.addEventListener('click', closePendingDrawer);
  document.getElementById('drawer-close')?.addEventListener('click', closeApprovalDrawer);
  document.getElementById('approval-overlay')?.addEventListener('click', closeApprovalDrawer);

  document.addEventListener('DOMContentLoaded', () => {
    loadToday();
    loadApprovals();
    document.getElementById('btn-walk-in')?.addEventListener('click', showWalkInModal);
  });
})();
</script>

<% else %>

