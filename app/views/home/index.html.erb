          <div class="disp-services">
            <% slot_data[:services].first(3).each_with_index do |svc, i| %>
            <div class="disp-svc-row">
              <span class="disp-svc-name"><%= svc.title %></span>
              <span class="disp-svc-price" style="<%= i == slot_data[:services].first(3).length - 1 ? 'color:var(--lime);' : '' %>">R$ <%= number_with_precision(svc.price, precision: 0) %></span>
            </div>
            <% end %>
          </div>
          <%= link_to checkout_disponivel_index_path(car_wash_id: slot_data[:car_wash].id, service_id: slot_data[:services].first.id, slot: slot_data[:slot].iso8601), class: "disp-btn" do %><i class="fas fa-bolt"></i> RESERVAR<% end %>
        </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-banner"><i class="fas fa-car-wash"></i><div><div class="empty-banner-title">Nenhuma vaga disponível agora</div><div class="empty-banner-text">Sem vagas nos próximos 30 min num raio de 5km.</div></div></div>
    <% end %>
  </div>
  <div class="home-divider"><div class="home-divider-line"></div></div>
  <% end %>

  <div class="home-section">
