<div id="loov-cursor"></div>
<div id="loov-cursor-trail"></div>
<div id="page-transition"></div>

<style>
  :root{--lime:#afff2d;--lime-dim:#8fcc24;--black:#000;--surface-2:#0d0d0d;--surface-3:#141414;--border:#1a1a1a;--text-muted:#444;--white:#fff;}
  #loov-cursor{position:fixed;width:8px;height:8px;background:var(--lime);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .18s,height .18s;mix-blend-mode:difference;}
  #loov-cursor-trail{position:fixed;width:38px;height:38px;border:1px solid rgba(175,255,45,0.25);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .25s,height .25s;}
  body.cursor-hover #loov-cursor{width:14px;height:14px;}
  body.cursor-hover #loov-cursor-trail{width:58px;height:58px;border-color:rgba(175,255,45,0.45);}
  @media(hover:none){#loov-cursor,#loov-cursor-trail{display:none;}}
  #page-transition{position:fixed;inset:0;z-index:10000;background:#000;transform:translateY(100%);pointer-events:none;}
  #page-transition.enter{animation:pgEnter .42s cubic-bezier(.76,0,.24,1) forwards;}
  #page-transition.exit{animation:pgExit .42s cubic-bezier(.76,0,.24,1) forwards;}
  @keyframes pgEnter{from{transform:translateY(100%)}to{transform:translateY(0)}}
  @keyframes pgExit{from{transform:translateY(0)}to{transform:translateY(-100%)}}
  *{box-sizing:border-box;}body{cursor:none;background:#000;font-family:'DM Sans',sans-serif;}

  .checkout-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1.5rem;padding-top:80px;}

  .checkout-card{
    width:100%;max-width:440px;
    background:var(--surface-2);border:1px solid rgba(255,255,255,0.07);
    border-radius:24px;overflow:hidden;
    box-shadow:0 32px 80px rgba(0,0,0,0.95);
    opacity:0;animation:revealUp .8s cubic-bezier(.16,1,.3,1) forwards .1s;
  }
  .checkout-card::before{content:'';display:block;height:2px;background:linear-gradient(to right,transparent,rgba(175,255,45,0.35),transparent);}

  .ck-body{padding:1.75rem 1.75rem 1.25rem;}
  .ck-eyebrow{font-family:'Montserrat',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(175,255,45,.4);margin-bottom:.5rem;}
  .ck-name{font-family:'Bebas Neue',sans-serif;font-size:1.875rem;color:var(--white);line-height:1;letter-spacing:.02em;margin-bottom:.25rem;}
  .ck-service{font-size:.875rem;color:var(--text-muted);margin-bottom:1.5rem;}

  .ck-rows{display:flex;flex-direction:column;gap:.625rem;margin-bottom:1.5rem;}
  .ck-row{display:flex;justify-content:space-between;align-items:center;}
  .ck-row-label{font-size:.78rem;color:var(--text-muted);}
  .ck-row-val{font-size:.875rem;color:var(--white);font-weight:500;}
  .ck-row-val.lime{color:var(--lime);}
  .ck-row-val.muted{color:#2a2a2a;}

  .ck-divider{height:1px;background:var(--border);margin-bottom:1.5rem;}

  .ck-total-row{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:1.5rem;}
  .ck-total-label{font-size:.72rem;color:var(--text-muted);}
  .ck-total-val{font-family:'Bebas Neue',sans-serif;font-size:2.25rem;color:var(--lime);letter-spacing:.02em;line-height:1;}

  /* Cartão salvo */
  .ck-card-info{display:flex;align-items:center;gap:.75rem;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:.875rem 1rem;margin-bottom:1.25rem;}
  .ck-card-icon{width:36px;height:36px;border-radius:8px;background:rgba(175,255,45,.08);border:1px solid rgba(175,255,45,.15);display:flex;align-items:center;justify-content:center;color:var(--lime);font-size:.875rem;flex-shrink:0;}
  .ck-card-label{font-size:.72rem;color:var(--text-muted);}
  .ck-card-val{font-size:.875rem;color:var(--white);font-weight:500;margin-top:.1rem;}

  /* Sem cartão */
  .ck-no-card{display:flex;align-items:flex-start;gap:.75rem;background:rgba(248,113,113,.05);border:1px solid rgba(248,113,113,.15);border-radius:12px;padding:1rem 1.125rem;margin-bottom:1.25rem;}
  .ck-no-card i{color:#f87171;margin-top:.1rem;flex-shrink:0;}
  .ck-no-card-text{font-size:.8rem;color:#888;line-height:1.55;}
  .ck-no-card-text strong{color:var(--white);}

  .ck-note{font-size:.72rem;color:var(--text-muted);line-height:1.55;margin-bottom:1.25rem;padding:.75rem;background:rgba(175,255,45,.03);border:1px solid rgba(175,255,45,.08);border-radius:10px;}
  .ck-note strong{color:var(--white);}

  .ck-footer{padding:1.25rem 1.75rem 1.75rem;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:.625rem;}

  .ck-btn{width:100%;border:none;border-radius:100px;padding:.9375rem;font-family:'DM Sans',sans-serif;font-size:.9375rem;font-weight:700;cursor:pointer;transition:all .22s;display:flex;align-items:center;justify-content:center;gap:.5rem;}
  .ck-btn-confirm{background:var(--lime);color:#000;}
  .ck-btn-confirm:hover:not(:disabled){background:#8fcc24;transform:translateY(-1px);}
  .ck-btn-confirm:disabled{opacity:.5;cursor:not-allowed;transform:none;}
  .ck-btn-card{background:rgba(175,255,45,.08);color:var(--lime);border:1px solid rgba(175,255,45,.2);}
  .ck-btn-card:hover{background:rgba(175,255,45,.14);}

  .ck-btn-back{display:block;text-align:center;font-size:.78rem;color:var(--text-muted);text-decoration:none;transition:color .2s;}
  .ck-btn-back:hover{color:var(--lime);}

  .ck-error{color:#f87171;font-size:.78rem;text-align:center;margin-top:.25rem;display:none;}

  .spinner{display:inline-block;width:16px;height:16px;border:2px solid rgba(0,0,0,.3);border-top-color:#000;border-radius:50%;animation:spin .7s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg)}}
  @keyframes revealUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
</style>

<div class="checkout-wrap">
  <div class="checkout-card">
    <div class="ck-body">
      <div class="ck-eyebrow">Confirmação de reserva</div>
      <div class="ck-name"><%= @car_wash.name %></div>
      <div class="ck-service"><%= @service.title %> · <%= @service.duration %> min</div>

      <div class="ck-rows">
        <div class="ck-row">
          <span class="ck-row-label">Horário</span>
          <span class="ck-row-val"><%= @slot.strftime("%H:%M") %> — hoje, <%= @slot.strftime("%d/%m") %></span>
        </div>
        <div class="ck-row">
          <span class="ck-row-label">Valor total</span>
          <span class="ck-row-val">R$ <%= number_with_precision(@total_price, precision: 2) %></span>
        </div>
        <div class="ck-row">
          <span class="ck-row-label">Pagar no local (65%)</span>
          <span class="ck-row-val muted">R$ <%= number_with_precision(@remaining, precision: 2) %></span>
        </div>
      </div>

      <div class="ck-divider"></div>

      <div class="ck-total-row">
        <span class="ck-total-label">Cobrado agora (35%)</span>
        <span class="ck-total-val">R$ <%= number_with_precision(@prepayment, precision: 2) %></span>
      </div>

      <% if @has_card %>
        <!-- Cartão cadastrado -->
        <div class="ck-card-info">
          <div class="ck-card-icon"><i class="fas fa-credit-card"></i></div>
          <div>
            <div class="ck-card-label">Cartão cadastrado</div>
            <div class="ck-card-val"><%= @card_display %></div>
          </div>
        </div>
        <div class="ck-note">
          O lava-rápido tem <strong>3 minutos</strong> para confirmar.
          Se não confirmar, <strong>nenhum valor é cobrado</strong>.
          O restante é pago diretamente no local.
        </div>
      <% else %>
        <!-- Sem cartão -->
        <div class="ck-no-card">
          <i class="fas fa-credit-card"></i>
          <div class="ck-no-card-text">
            <strong>Nenhum cartão cadastrado.</strong><br>
            Você precisa de um cartão para reservar na aba Disponíveis. Cadastre agora e volte para concluir a reserva.
          </div>
        </div>
      <% end %>
    </div>

    <div class="ck-footer">
      <% if @has_card %>
        <button class="ck-btn ck-btn-confirm" id="confirm-btn">
          <i class="fas fa-bolt"></i> Confirmar reserva
        </button>
      <% else %>
        <%= link_to edit_client_profile_path(add_card: true), class: "ck-btn ck-btn-card" do %>
          <i class="fas fa-credit-card"></i> Cadastrar cartão
        <% end %>
      <% end %>
      <div class="ck-error" id="ck-error"></div>
      <%= link_to disponivel_index_path, class: "ck-btn-back" do %>
        ← Cancelar e voltar
      <% end %>
    </div>
  </div>
</div>

<% if @has_card %>
<script>
  const CSRF        = document.querySelector('meta[name="csrf-token"]').content;
  const CAR_WASH_ID = <%= @car_wash.id %>;
  const SERVICE_ID  = <%= @service.id %>;
  const SLOT        = "<%= @slot.iso8601 %>";

  (function(){
    const cursor=document.getElementById('loov-cursor'),trail=document.getElementById('loov-cursor-trail');
    if(cursor&&trail){let mx=-100,my=-100,tx=-100,ty=-100;document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});(function anim(){tx+=(mx-tx)*0.12;ty+=(my-ty)*0.12;trail.style.left=tx+'px';trail.style.top=ty+'px';requestAnimationFrame(anim);})();document.addEventListener('mouseover',e=>{if(e.target.closest('a,button'))document.body.classList.add('cursor-hover');});document.addEventListener('mouseout',e=>{if(e.target.closest('a,button'))document.body.classList.remove('cursor-hover');});}
    const pt=document.getElementById('page-transition');
    if(pt){document.addEventListener('click',e=>{const link=e.target.closest('a[href]');if(!link)return;const href=link.getAttribute('href');if(!href||href.startsWith('#'))return;e.preventDefault();pt.classList.add('enter');setTimeout(()=>window.location.href=href,400);});window.addEventListener('pageshow',()=>{pt.classList.remove('enter');pt.classList.add('exit');setTimeout(()=>pt.classList.remove('exit'),440);});}
  })();

  document.getElementById('confirm-btn').addEventListener('click', async function() {
    const btn     = this;
    const errorEl = document.getElementById('ck-error');
    btn.disabled  = true;
    btn.innerHTML = '<span class="spinner"></span> Processando...';
    errorEl.style.display = 'none';

    try {
      const res = await fetch('/disponivel', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF, 'Accept': 'application/json' },
        body: JSON.stringify({ car_wash_id: CAR_WASH_ID, service_id: SERVICE_ID, slot: SLOT })
      });
      const data = await res.json();

      if (data.ok) {
        window.location.href = '/disponivel/' + data.appointment_id + '/confirmacao';
      } else if (data.redirect) {
        window.location.href = data.redirect;
      } else {
        errorEl.textContent   = data.error || 'Erro ao criar reserva.';
        errorEl.style.display = 'block';
        btn.disabled  = false;
        btn.innerHTML = '<i class="fas fa-bolt"></i> Confirmar reserva';
      }
    } catch(e) {
      errorEl.textContent   = 'Erro de conexão. Tente novamente.';
      errorEl.style.display = 'block';
      btn.disabled  = false;
      btn.innerHTML = '<i class="fas fa-bolt"></i> Confirmar reserva';
    }
  });
</script>
<% else %>
<script>
  (function(){
    const cursor=document.getElementById('loov-cursor'),trail=document.getElementById('loov-cursor-trail');
    if(cursor&&trail){let mx=-100,my=-100,tx=-100,ty=-100;document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});(function anim(){tx+=(mx-tx)*0.12;ty+=(my-ty)*0.12;trail.style.left=tx+'px';trail.style.top=ty+'px';requestAnimationFrame(anim);})();}
    const pt=document.getElementById('page-transition');
    if(pt){document.addEventListener('click',e=>{const link=e.target.closest('a[href]');if(!link)return;const href=link.getAttribute('href');if(!href||href.startsWith('#'))return;e.preventDefault();pt.classList.add('enter');setTimeout(()=>window.location.href=href,400);});window.addEventListener('pageshow',()=>{pt.classList.remove('enter');pt.classList.add('exit');setTimeout(()=>pt.classList.remove('exit'),440);});}
  })();
</script>
<% end %>
