<div id="loov-cursor"></div>
<div id="loov-cursor-trail"></div>
<div id="page-transition"></div>

<style>
  :root {
    --lime: #afff2d;
    --lime-dim: #8fcc24;
    --black: #000;
    --surface: #0a0a0a;
    --surface-2: #0d0d0d;
    --surface-3: #141414;
    --border: #1a1a1a;
    --border-soft: #222;
    --text-muted: #444;
    --text-secondary: #777;
    --white: #fff;
  }

  /* ── CURSOR ─────────────────────────────────────────── */
  #loov-cursor { position:fixed;width:8px;height:8px;background:var(--lime);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .18s ease,height .18s ease;mix-blend-mode:difference; }
  #loov-cursor-trail { position:fixed;width:38px;height:38px;border:1px solid rgba(175,255,45,0.25);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .25s ease,height .25s ease,border-color .25s ease; }
  body.cursor-hover #loov-cursor { width:14px;height:14px; }
  body.cursor-hover #loov-cursor-trail { width:58px;height:58px;border-color:rgba(175,255,45,0.45); }
  @media(hover:none){#loov-cursor,#loov-cursor-trail{display:none;}}

  /* ── PAGE TRANSITION ─────────────────────────────────── */
  #page-transition { position:fixed;inset:0;z-index:10000;background:#000;transform:translateY(100%);pointer-events:none; }
  #page-transition.enter { animation:pgEnter .42s cubic-bezier(.76,0,.24,1) forwards; }
  #page-transition.exit  { animation:pgExit  .42s cubic-bezier(.76,0,.24,1) forwards; }
  @keyframes pgEnter{from{transform:translateY(100%)}to{transform:translateY(0)}}
  @keyframes pgExit{from{transform:translateY(0)}to{transform:translateY(-100%)}}

  * { box-sizing: border-box; }
  body { cursor: none; }

  .reg-wrap {
    min-height: 100vh;
    background: var(--black);
    font-family: 'DM Sans', sans-serif;
    padding-top: 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
  }

  /* ── LADO ESQUERDO — EDITORIAL ────────────────────────── */
  .reg-editorial {
    padding: 4rem 3rem 4rem 4rem;
    display: flex; flex-direction: column; justify-content: center;
    min-height: calc(100vh - 60px);
    border-right: 1px solid var(--border);
    opacity: 0; animation: revealUp .9s cubic-bezier(.16,1,.3,1) forwards .1s;
  }

  .reg-eyebrow {
    display: inline-flex; align-items: center; gap: .6rem;
    font-size: .68rem; font-weight: 500; letter-spacing: .25em;
    text-transform: uppercase; color: var(--lime); margin-bottom: 1.5rem;
  }
  .reg-eyebrow::before { content:''; display:block; width:28px; height:1px; background:var(--lime); }

  .reg-editorial-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: .92; color: var(--white); margin: 0 0 1.5rem;
  }
  .reg-editorial-title span { color: var(--lime); }

  .reg-editorial-sub {
    font-size: .9375rem; color: var(--text-secondary);
    font-weight: 300; line-height: 1.65; max-width: 340px;
  }

  /* Detalhe decorativo */
  .reg-editorial-steps {
    margin-top: 3rem; padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: .875rem;
  }

  .reg-step {
    display: flex; align-items: center; gap: .875rem;
    font-size: .8rem; color: var(--text-muted);
  }

  .reg-step-num {
    width: 22px; height: 22px; border-radius: 50%;
    border: 1px solid rgba(175,255,45,.3);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif; font-size: .75rem;
    color: var(--lime); flex-shrink: 0; letter-spacing: .04em;
  }

  /* ── LADO DIREITO — FORM ─────────────────────────────── */
  .reg-form-side {
    padding: 3rem 4rem 3rem 3rem;
    display: flex; flex-direction: column; justify-content: center;
    min-height: calc(100vh - 60px);
    opacity: 0; animation: revealUp .9s cubic-bezier(.16,1,.3,1) forwards .25s;
    overflow-y: auto;
  }

  .reg-form-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1; color: var(--white); margin: 0 0 1.75rem;
  }
  .reg-form-title span { color: var(--lime); }

  /* ── ROLE SELECTOR ───────────────────────────────────── */
  .role-selector {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: .625rem; margin-bottom: 1.5rem;
  }

  .role-option { display: none; }

  .role-label {
    display: flex; flex-direction: column; gap: .3rem;
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: 12px; padding: .875rem 1rem;
    cursor: none; transition: all .2s ease; user-select: none;
  }
  .role-label:hover { border-color: rgba(175,255,45,.2); }

  .role-option:checked + .role-label {
    border-color: var(--lime);
    background: rgba(175,255,45,.05);
    box-shadow: 0 0 0 1px var(--lime);
  }

  .role-label-title {
    font-size: .875rem; font-weight: 500; color: var(--white);
    display: flex; align-items: center; gap: .4rem;
  }

  .role-label-title i { color: var(--lime); font-size: .75rem; }

  .role-label-desc { font-size: .72rem; color: var(--text-muted); line-height: 1.4; }

  /* ── FORM FIELDS ─────────────────────────────────────── */
  .reg-form { display: flex; flex-direction: column; gap: 1rem; }

  .reg-field { display: flex; flex-direction: column; gap: .4rem; }

  .reg-label {
    font-size: .72rem; font-weight: 500; color: var(--text-muted);
    letter-spacing: .08em; text-transform: uppercase;
  }

  .reg-input {
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: 10px; padding: .875rem 1rem;
    font-family: 'DM Sans', sans-serif; font-size: .9375rem;
    color: var(--white); outline: none; transition: all .2s ease;
    width: 100%; cursor: none;
  }
  .reg-input::placeholder { color: var(--text-muted); }
  .reg-input:focus { border-color: var(--lime); box-shadow: 0 0 0 3px rgba(175,255,45,.07); }

  /* Campos do cliente — hidden por padrão */
  .client-fields { display: none; }
  .client-fields.visible { display: contents; }

  .reg-submit {
    background: var(--lime); color: var(--black); border: none;
    border-radius: 100px; padding: .9rem 1.75rem;
    font-family: 'DM Sans', sans-serif; font-size: .9375rem; font-weight: 600;
    cursor: none; transition: all .22s ease; width: 100%; margin-top: .375rem;
  }
  .reg-submit:hover { background: var(--lime-dim); transform: translateY(-2px); box-shadow: 0 10px 28px rgba(175,255,45,.18); }

  .reg-links {
    display: flex; flex-direction: column; gap: .5rem;
    margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border);
  }
  .reg-links a {
    font-size: .875rem; color: var(--text-muted); text-decoration: none;
    transition: color .2s ease; display: flex; align-items: center; gap: .4rem;
  }
  .reg-links a:hover { color: var(--lime); }

  /* ── ANIMAÇÕES ───────────────────────────────────────── */
  @keyframes revealUp { from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)} }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media(max-width:768px) {
    .reg-wrap { grid-template-columns: 1fr; }
    .reg-editorial { display: none; }
    .reg-form-side { padding: 2.5rem 1.5rem; min-height: auto; }
    .reg-form-title { font-size: 2rem; }
  }
</style>

<div class="reg-wrap">

  <!-- LADO EDITORIAL -->
  <div class="reg-editorial">
    <div class="reg-eyebrow">Bem-vindo à Loov</div>
    <h1 class="reg-editorial-title">
      Crie sua<br>
      <span>conta.</span>
    </h1>
    <p class="reg-editorial-sub">
      Escolha seu perfil e comece a usar a Loov em menos de 2 minutos.
    </p>
    <div class="reg-editorial-steps">
      <div class="reg-step"><div class="reg-step-num">1</div>Escolha seu perfil</div>
      <div class="reg-step"><div class="reg-step-num">2</div>Preencha seus dados</div>
      <div class="reg-step"><div class="reg-step-num">3</div>Confirme seu e-mail</div>
    </div>
  </div>

  <!-- FORM -->
  <div class="reg-form-side">
    <h2 class="reg-form-title">Criar conta<span>.</span></h2>

    <!-- SELETOR DE PERFIL -->
    <div class="role-selector" id="role-selector">
      <div>
        <input type="radio" name="role_ui" id="role-client" value="client" class="role-option" checked>
        <label for="role-client" class="role-label">
          <div class="role-label-title"><i class="fas fa-user"></i> Cliente</div>
          <div class="role-label-desc">Agende serviços em lava-rápidos próximos a você</div>
        </label>
      </div>
      <div>
        <input type="radio" name="role_ui" id="role-owner" value="owner" class="role-option">
        <label for="role-owner" class="role-label">
          <div class="role-label-title"><i class="fas fa-store"></i> Proprietário</div>
          <div class="role-label-desc">Gerencie seu lava-rápido e receba agendamentos</div>
        </label>
      </div>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "reg-form", id: "reg-form" }) do |f| %>

      <%= f.hidden_field :role, id: "role-hidden", value: "client" %>

      <!-- Campos do cliente -->
      <div class="client-fields visible" id="client-fields">
        <div class="reg-field">
          <label class="reg-label">Nome completo</label>
          <%= f.text_field :full_name, class: "reg-input", placeholder: "Seu nome completo", id: "full_name_field" %>
        </div>
        <div class="reg-field">
          <label class="reg-label">Telefone</label>
          <%= f.text_field :phone, class: "reg-input", placeholder: "(11) 99999-9999", id: "phone_field", maxlength: 15 %>
        </div>
      </div>

      <div class="reg-field">
        <label class="reg-label">E-mail</label>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "reg-input", placeholder: "seu@email.com" %>
      </div>

      <div class="reg-field">
        <label class="reg-label">Senha</label>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "reg-input", placeholder: "Mínimo #{resource.class.password_length.min} caracteres" %>
      </div>

      <div class="reg-field">
        <label class="reg-label">Confirmar senha</label>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "reg-input", placeholder: "Repita a senha" %>
      </div>

      <%= f.submit "Criar conta", class: "reg-submit" %>

    <% end %>

    <div class="reg-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>

</div>

<script>
(function(){
  // CURSOR
  const cursor=document.getElementById('loov-cursor'),trail=document.getElementById('loov-cursor-trail');
  if(cursor&&trail){let mx=-100,my=-100,tx=-100,ty=-100;document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});(function anim(){tx+=(mx-tx)*0.12;ty+=(my-ty)*0.12;trail.style.left=tx+'px';trail.style.top=ty+'px';requestAnimationFrame(anim);})();document.addEventListener('mouseover',e=>{if(e.target.closest('a,button,input,select,textarea'))document.body.classList.add('cursor-hover');});document.addEventListener('mouseout',e=>{if(e.target.closest('a,button,input,select,textarea'))document.body.classList.remove('cursor-hover');});document.addEventListener('mouseleave',()=>{cursor.style.opacity='0';trail.style.opacity='0';});document.addEventListener('mouseenter',()=>{cursor.style.opacity='1';trail.style.opacity='1';});}

  // PAGE TRANSITION
  const pt=document.getElementById('page-transition');
  if(pt){document.addEventListener('click',e=>{const link=e.target.closest('a[href]');if(!link)return;const href=link.getAttribute('href');if(!href||href.startsWith('#')||href.startsWith('mailto')||link.target==='_blank')return;if(href.startsWith('http')&&!href.includes(window.location.hostname))return;e.preventDefault();pt.classList.add('enter');setTimeout(()=>window.location.href=href,400);});window.addEventListener('pageshow',()=>{pt.classList.remove('enter');pt.classList.add('exit');setTimeout(()=>pt.classList.remove('exit'),440);});}

  // ROLE TOGGLE
  document.addEventListener('DOMContentLoaded',function(){
    var radios=document.querySelectorAll('input[name="role_ui"]');
    var clientFields=document.getElementById('client-fields');
    var roleHidden=document.getElementById('role-hidden');
    var phoneField=document.getElementById('phone_field');
    var nameField=document.getElementById('full_name_field');

    radios.forEach(function(radio){
      radio.addEventListener('change',function(){
        var isClient=this.value==='client';
        roleHidden.value=this.value;
        clientFields.classList.toggle('visible',isClient);
        if(nameField)nameField.required=isClient;
        if(phoneField)phoneField.required=isClient;
      });
    });

    // Máscara telefone
    if(phoneField){
      phoneField.addEventListener('input',function(){
        var v=this.value.replace(/\D/g,'');
        v=v.length<=10?v.replace(/^(\d{2})(\d{4})(\d{0,4})/,'($1) $2-$3'):v.replace(/^(\d{2})(\d{5})(\d{0,4})/,'($1) $2-$3');
        this.value=v;
      });
    }

    // Restaura estado se houver erro de validação (página recarregada)
    var currentRole=roleHidden.value||'client';
    var matchingRadio=document.querySelector('input[name="role_ui"][value="'+currentRole+'"]');
    if(matchingRadio){
      matchingRadio.checked=true;
      var isClient=currentRole==='client';
      clientFields.classList.toggle('visible',isClient);
    }
  });
})();
</script>
