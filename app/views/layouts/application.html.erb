<!DOCTYPE html>
<html data-theme="dark">
<head>
  <title>Loov</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=Montserrat:wght@400;500;700&display=swap">
  <link rel="stylesheet" href="/assets/tailwind.css">
  <link rel="stylesheet" href="/assets/application.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css">
  <script src="https://js.stripe.com/v3/"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js"></script>
  <style>
    #matter-wrap-container {
      position: fixed;
      top: 0; left: 0;
      width: 100vw; height: 100vh;
      z-index: 0;
      overflow: hidden;
    }
    #matter-wrap-container canvas {
      display: block;
      width: 100vw !important;
      height: 100vh !important;
    }
  </style>
</head>
<body>
  <%= render 'layouts/navbar' %>
  <main>
    <%= yield %>
  </main>
  <script>
    document.addEventListener('DOMContentLoaded', () => {

      // Animações de entrada legadas
      document.querySelectorAll('.fade-in-card').forEach((card, i) => {
        setTimeout(() => { card.style.opacity = '1'; card.style.transform = 'translateY(0)'; }, i * 150);
      });
      document.querySelectorAll('.fade-in-welcome').forEach((el, i) => {
        setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }, i * 200);
      });
      const searchSection = document.querySelector('.fade-in-search');
      if (searchSection) setTimeout(() => { searchSection.style.opacity = '1'; searchSection.style.transform = 'translateY(0)'; }, 400);

      // Typewriter no search
      const placeholderText = "Buscar lava-rápido ou serviço...";
      const searchInput = document.getElementById('search-input');
      if (searchInput) {
        searchInput.setAttribute('placeholder', '');
        let i = 0;
        function typeWriter() {
          if (i < placeholderText.length) {
            searchInput.setAttribute('placeholder', searchInput.getAttribute('placeholder') + placeholderText.charAt(i));
            i++;
            setTimeout(typeWriter, 50);
          }
        }
        setTimeout(typeWriter, 600);
      }

      // Geolocalização automática para clientes
      const findNearby = () => {
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              const url = new URL(window.location);
              url.searchParams.set('latitude', pos.coords.latitude);
              url.searchParams.set('longitude', pos.coords.longitude);
              window.location.href = url.toString();
            },
            (err) => console.error('Geolocation error:', err),
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
          );
        }
      };
      const urlParams = new URLSearchParams(window.location.search);
      <% if user_signed_in? && current_user.client? %>
      if (!window.location.pathname.includes('/client/profile') &&
          (!urlParams.has('latitude') || !urlParams.has('longitude'))) {
        findNearby();
      }
      <% end %>

      // Matter.js para owner/attendant
      <% if user_signed_in? && (current_user.owner? || current_user.attendant?) %>
      if (typeof Matter === 'undefined') return;
      const { Engine, Render, World, Bodies, Body, Mouse, MouseConstraint, Events, Vector } = Matter;
      const engine = Engine.create();
      engine.world.gravity.y = 0;
      const canvas = document.getElementById('matter-wrap-canvas');
      if (!canvas) return;
      const W = window.innerWidth;
      const H = window.innerHeight;
      canvas.width  = W;
      canvas.height = H;
      const render = Render.create({
        canvas, engine,
        options: { width: W, height: H, wireframes: false, background: '#000000' }
      });
      window.addEventListener('resize', () => {
        const nW = window.innerWidth, nH = window.innerHeight;
        render.canvas.width  = nW; render.canvas.height = nH;
        render.options.width = nW; render.options.height = nH;
      });
      const wallOpts = { isStatic: true, render: { fillStyle: '#0a0a0a' } };
      const off = 50;
      World.add(engine.world, [
        Bodies.rectangle(W/2,   -off,    W+2*off, off*2, wallOpts),
        Bodies.rectangle(W/2,   H+off,   W+2*off, off*2, wallOpts),
        Bodies.rectangle(-off,   H/2,    off*2, H+2*off, wallOpts),
        Bodies.rectangle(W+off,  H/2,    off*2, H+2*off, wallOpts)
      ]);
      const makeBody = (type, fill) => {
        const size = Math.random() * 16 + 10;
        const x = Math.random() * (W-60) + 30;
        const y = Math.random() * (H-60) + 30;
        const opts = { restitution: 0.6, friction: 0, frictionAir: 0.008, render: { fillStyle: fill } };
        const b = type === 'circle' ? Bodies.circle(x, y, size, opts) : Bodies.rectangle(x, y, size, size, opts);
        Body.setVelocity(b, { x: (Math.random()-0.5)*2, y: (Math.random()-0.5)*2 });
        return b;
      };
      const allBodies = [
        ...Array.from({length:10}, () => makeBody('rect',   '#ffffff')),
        ...Array.from({length:8},  () => makeBody('circle', '#afff2d')),
        ...Array.from({length:6},  () => makeBody('circle', '#333333'))
      ];
      World.add(engine.world, allBodies);
      const mouse = Mouse.create(render.canvas);
      World.add(engine.world, MouseConstraint.create(engine, { mouse, constraint: { stiffness: 0.2, render: { visible: false } } }));
      render.mouse = mouse;
      Events.on(engine, 'beforeUpdate', () => {
        allBodies.forEach(body => {
          const vel = body.velocity;
          const speed = Vector.magnitude(vel);
          if (speed < 0.8) Body.setVelocity(body, Vector.mult(Vector.normalise(speed > 0 ? vel : {x:1,y:0}), 0.8));
          const dist = Vector.magnitude(Vector.sub(body.position, mouse.position));
          if (dist < 120 && dist > 0) {
            Body.applyForce(body, body.position, Vector.mult(Vector.normalise(Vector.sub(body.position, mouse.position)), (1-dist/120)*0.025));
          }
        });
      });
      Engine.run(engine);
      Render.run(render);
      <% end %>
    });
  </script>
</body>
</html>
