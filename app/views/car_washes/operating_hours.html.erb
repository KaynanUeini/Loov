<h1>Horários de Funcionamento</h1>

<h2>Adicionar Novo Horário</h2>

<%= form_with(model: [@car_wash, @operating_hour], url: create_operating_hour_car_wash_path(@car_wash), local: true) do |form| %>
  <% if @operating_hour.errors.any? %>
    <div class="alert alert-danger">
      <h4>
        <% if @operating_hour.errors[:day_of_week].include?("já está na lista de horários de funcionamento") %>
          Não é possível adicionar um dia que já está na lista
        <% else %>
          <% if @operating_hour.errors.count == 1 %>
            1 erro impediu a criação:
          <% else %>
            <%= @operating_hour.errors.count %> erros impediram a criação:
          <% end %>
          <ul>
            <% @operating_hour.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        <% end %>
      </h4>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :day_of_week, "Dia da Semana" %>
    <%= form.select :day_of_week, options_for_select([
      ["Domingo", 0],
      ["Segunda-feira", 1],
      ["Terça-feira", 2],
      ["Quarta-feira", 3],
      ["Quinta-feira", 4],
      ["Sexta-feira", 5],
      ["Sábado", 6]
    ], @operating_hour.day_of_week) %>
  </div>

  <div class="field">
    <%= form.label :opens_at, "Horário de Abertura" %>
    <%= form.time_field :opens_at %>
  </div>

  <div class="field">
    <%= form.label :closes_at, "Horário de Fechamento" %>
    <%= form.time_field :closes_at %>
  </div>

  <div class="actions">
    <%= form.submit "Adicionar Horário" %>
  </div>
<% end %>

<h2>Horários Existentes</h2>
<% if @operating_hours.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Dia da Semana</th>
        <th>Horário de Abertura</th>
        <th>Horário de Fechamento</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @operating_hours.each do |hour| %>
        <% if hour.id.present? %>
          <tr>
            <td><%= %w[Domingo Segunda-feira Terça-feira Quarta-feira Quinta-feira Sexta-feira Sábado][hour.day_of_week.to_i] %></td>
            <td><%= hour.opens_at ? hour.opens_at.strftime('%H:%M') : "Não definido" %></td>
            <td><%= hour.closes_at ? hour.closes_at.strftime('%H:%M') : "Não definido" %></td>
            <td>
              <%= link_to 'Editar', edit_operating_hour_car_wash_path(@car_wash, hour) %>
              <%= link_to 'Excluir', destroy_operating_hour_car_wash_path(@car_wash, hour), method: :delete, data: { confirm: 'Tem certeza que deseja excluir este horário de funcionamento?' }, class: 'btn btn-danger btn-sm' %>
            </td>
          </tr>
        <% else %>
          <tr>
            <td colspan="4">Horário inválido (ID ausente)</td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Nenhum horário de funcionamento cadastrado.</p>
<% end %>

<%= link_to 'Voltar', @car_wash %>
