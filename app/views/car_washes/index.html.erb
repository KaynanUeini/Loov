<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap');
  :root { --lime:#afff2d;--lime-dim:#8fcc24;--black:#000;--surface:#0a0a0a;--surface-2:#111;--surface-3:#1a1a1a;--border:#222;--text-muted:#666;--text-secondary:#999;--white:#fff; }
  *{box-sizing:border-box}
  .list-wrap{min-height:100vh;background:var(--black);font-family:'DM Sans',sans-serif;padding-top:64px;padding-bottom:4rem;}
  .list-inner{max-width:1200px;margin:0 auto;padding:3rem 1.5rem 0;}

  .list-eyebrow{display:inline-flex;align-items:center;gap:.5rem;font-size:.7rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);margin-bottom:1rem;opacity:0;animation:fadeUp .6s ease forwards .1s}
  .list-eyebrow::before{content:'';display:block;width:24px;height:1px;background:var(--lime)}
  .list-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,8vw,5rem);line-height:1;color:var(--white);margin:0 0 2rem;opacity:0;animation:fadeUp .6s ease forwards .2s}
  .list-title span{color:var(--lime)}

  .search-wrap{margin-bottom:1.5rem;opacity:0;animation:fadeUp .6s ease forwards .3s}
  .search-inner{position:relative;display:flex;align-items:center}
  .search-icon{position:absolute;left:1.25rem;color:var(--text-muted);font-size:.9rem;pointer-events:none}
  .search-input{width:100%;background:var(--surface-2);border:1px solid var(--border);border-radius:100px;padding:1rem 1rem 1rem 3rem;font-family:'DM Sans',sans-serif;font-size:.9375rem;color:var(--white);outline:none;transition:all .2s ease}
  .search-input::placeholder{color:var(--text-muted)}
  .search-input:focus{border-color:var(--lime);box-shadow:0 0 0 3px rgba(175,255,45,.08)}
  .search-submit{position:absolute;right:.375rem;background:var(--lime);color:var(--black);border:none;border-radius:100px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.8rem;transition:all .2s ease}
  .search-submit:hover{background:var(--lime-dim)}

  .groups-wrap{margin-bottom:1rem;opacity:0;animation:fadeUp .6s ease forwards .4s}
  .groups-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:.75rem;}
  .groups-row{display:flex;gap:.5rem;flex-wrap:wrap;}
  .group-btn{display:inline-flex;align-items:center;gap:.5rem;background:var(--surface-2);border:1px solid var(--border);border-radius:12px;padding:.6rem 1.1rem;font-family:'DM Sans',sans-serif;font-size:.875rem;font-weight:500;color:var(--text-muted);cursor:pointer;text-decoration:none;transition:all .2s ease;}
  .group-btn:hover{border-color:rgba(175,255,45,.3);color:var(--white)}
  .group-btn.active{background:rgba(175,255,45,.1);border-color:var(--lime);color:var(--lime)}
  .group-btn i{font-size:.8rem;}

  .subcats-wrap{display:none;margin-bottom:1.5rem;padding:1rem 1.25rem;background:var(--surface-2);border:1px solid var(--border);border-radius:14px;animation:fadeUp .3s ease forwards;}
  .subcats-wrap.visible{display:block;}
  .subcats-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:.75rem;}
  .subcats-row{display:flex;gap:.4rem;flex-wrap:wrap;}
  .subcat-btn{display:inline-flex;align-items:center;background:var(--surface-3);border:1px solid var(--border);border-radius:100px;padding:.4rem .9rem;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:500;color:var(--text-muted);cursor:pointer;text-decoration:none;transition:all .2s ease;}
  .subcat-btn:hover{border-color:rgba(175,255,45,.3);color:var(--white)}
  .subcat-btn.active{background:rgba(175,255,45,.08);border-color:var(--lime);color:var(--lime)}

  .section-header{display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;margin-bottom:1rem;}
  .section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.5rem,4vw,2rem);color:var(--white);margin:0;font-weight:400}
  .section-count{font-size:.8rem;color:var(--text-muted);white-space:nowrap;padding-bottom:.2rem}
  .divider-line{height:1px;background:var(--border);margin-bottom:2rem}

  .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden}
  .car-wash-card{background:var(--surface);padding:1.75rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background .2s ease;opacity:0;transform:translateY(12px);animation:fadeUp .5s ease forwards}
  .car-wash-card:hover{background:var(--surface-2)}
  .car-wash-card:hover .card-arrow{transform:translate(3px,-3px);color:var(--lime)}
  .card-top{display:flex;align-items:center;justify-content:space-between}
  .card-avatar{width:48px;height:48px;border-radius:12px;background:var(--surface-3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:var(--lime);letter-spacing:.05em;flex-shrink:0}
  .card-arrow{color:var(--text-muted);font-size:1rem;transition:all .2s ease}
  .card-name{font-size:1.0625rem;font-weight:500;color:var(--white);line-height:1.3;margin:0}
  .card-meta{display:flex;flex-direction:column;gap:.4rem}
  .card-meta-item{display:flex;align-items:center;gap:.5rem;font-size:.8125rem;color:var(--text-muted);margin:0}
  .card-meta-item i{color:var(--lime);font-size:.7rem;width:12px;flex-shrink:0}
  .card-services{display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.25rem}
  .card-service-tag{font-size:.65rem;background:var(--surface-3);border:1px solid var(--border);color:var(--text-muted);padding:.2rem .5rem;border-radius:100px;}
  .card-badge{display:inline-flex;align-items:center;gap:.35rem;background:rgba(175,255,45,.08);color:var(--lime);font-size:.7rem;font-weight:500;letter-spacing:.05em;padding:.3rem .6rem;border-radius:100px;border:1px solid rgba(175,255,45,.15);width:fit-content;margin-top:auto}

  .empty-state{padding:4rem 0;text-align:center}
  .empty-icon{font-size:2.5rem;color:var(--border);margin-bottom:1rem}
  .empty-title{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--white);margin-bottom:.5rem}
  .empty-text{font-size:.875rem;color:var(--text-muted);margin-bottom:1.5rem}
  .empty-actions{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap}
  .btn-secondary{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.5rem;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:.875rem;font-weight:500;text-decoration:none;background:transparent;color:var(--white);border:1px solid var(--border);transition:all .2s ease}
  .btn-secondary:hover{border-color:var(--lime);color:var(--lime)}
  .btn-primary{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.5rem;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:.875rem;font-weight:500;text-decoration:none;background:var(--lime);color:var(--black);border:none;transition:all .2s ease}
  .btn-primary:hover{background:var(--lime-dim)}
  .back-link{display:inline-flex;align-items:center;gap:.4rem;font-size:.8rem;color:var(--text-muted);text-decoration:none;margin-bottom:2rem;transition:color .2s ease}
  .back-link:hover{color:var(--lime)}

  @keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
  @media(max-width:640px){.list-inner{padding:2rem 1.25rem 0}.groups-row{gap:.35rem}.cards-grid{grid-template-columns:1fr}}
  @media(min-width:768px){.cards-grid{grid-template-columns:repeat(2,1fr)}}
  @media(min-width:1024px){.cards-grid{grid-template-columns:repeat(3,1fr)}}
</style>

<div class="list-wrap">
  <div class="list-inner">

    <%= link_to root_path, class: "back-link" do %>
      <i class="fas fa-arrow-left"></i> Voltar
    <% end %>

    <div class="list-eyebrow">Lava-rápidos</div>
    <h1 class="list-title">Encontre o <span>seu.</span></h1>

    <div class="search-wrap">
      <%= form_with url: car_washes_path, method: :get, local: true do %>
        <%= hidden_field_tag :latitude, params[:latitude] if params[:latitude].present? %>
        <%= hidden_field_tag :longitude, params[:longitude] if params[:longitude].present? %>
        <div class="search-inner">
          <i class="fas fa-magnifying-glass search-icon"></i>
          <%= text_field_tag :search, params[:search], placeholder: "Buscar por nome ou endereço...", class: "search-input", autocomplete: "off" %>
          <button type="submit" class="search-submit"><i class="fas fa-arrow-right"></i></button>
        </div>
      <% end %>
    </div>

    <!-- Grupos principais -->
    <div class="groups-wrap">
      <div class="groups-label">O que você precisa?</div>
      <div class="groups-row">
        <%= link_to car_washes_path(search: params[:search], latitude: params[:latitude], longitude: params[:longitude]),
            class: "group-btn #{@selected_group.blank? ? 'active' : ''}" do %>
          <i class="fas fa-border-all"></i> Todos
        <% end %>
        <% icons = { "Lavagem" => "fa-droplet", "Estética" => "fa-spray-can-sparkles", "Higiene" => "fa-pump-soap", "Especiais" => "fa-wrench", "Outros" => "fa-ellipsis" } %>
        <% @groups.each do |group, _cats| %>
          <%= link_to car_washes_path(group: group, search: params[:search], latitude: params[:latitude], longitude: params[:longitude]),
              class: "group-btn #{@selected_group == group ? 'active' : ''}" do %>
            <i class="fas <%= icons[group] %>"></i> <%= group %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Subcategorias -->
    <% if @selected_group.present? && @subcategories.any? %>
    <div class="subcats-wrap visible">
      <div class="subcats-label">
        <% if @selected_group == "Lavagem" %>
          Tipo de lavagem
        <% else %>
          Especialidade
        <% end %>
      </div>
      <div class="subcats-row">
        <!-- Botão "Todos" -->
        <%= link_to car_washes_path(group: @selected_group, search: params[:search], latitude: params[:latitude], longitude: params[:longitude]),
            class: "subcat-btn #{@selected_category.blank? && @selected_service_title.blank? ? 'active' : ''}" do %>
          Todos em <%= @selected_group %>
        <% end %>

        <% if @selected_group == "Lavagem" %>
          <% @subcategories.each do |title| %>
            <%= link_to car_washes_path(group: @selected_group, service_title: title, search: params[:search], latitude: params[:latitude], longitude: params[:longitude]),
                class: "subcat-btn #{@selected_service_title == title ? 'active' : ''}" do %>
              <%= title %>
            <% end %>
          <% end %>
        <% else %>
          <% @subcategories.each do |cat| %>
            <%= link_to car_washes_path(group: @selected_group, category: cat, search: params[:search], latitude: params[:latitude], longitude: params[:longitude]),
                class: "subcat-btn #{@selected_category == cat ? 'active' : ''}" do %>
              <%= cat %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
    <% end %>

    <!-- Header da listagem -->
    <div class="section-header">
      <h2 class="section-title">
        <% if @selected_service_title.present? %>
          <%= @selected_service_title %>
        <% elsif @selected_category.present? %>
          <%= @selected_category %>
        <% elsif @selected_group.present? %>
          <%= @selected_group %>
        <% elsif params[:latitude].present? %>
          Próximos a você
        <% elsif params[:search].present? %>
          Resultados
        <% else %>
          Todos
        <% end %>
      </h2>
      <span class="section-count"><%= @car_washes.count %> encontrado<%= @car_washes.count == 1 ? '' : 's' %></span>
    </div>
    <div class="divider-line"></div>

    <% if @car_washes.empty? %>
      <div class="empty-state">
        <div class="empty-icon"><i class="fas fa-car-wash"></i></div>
        <h3 class="empty-title">Nenhum resultado</h3>
        <p class="empty-text">Nenhum lava-rápido oferece esse serviço na sua região ainda.</p>
        <div class="empty-actions">
          <%= link_to car_washes_path, class: "btn-secondary" do %>Limpar filtros<% end %>
          <%= link_to root_path, class: "btn-primary" do %>Voltar ao início<% end %>
        </div>
      </div>
    <% else %>
      <div class="cards-grid">
        <% @car_washes.each_with_index do |cw, i| %>
          <%= link_to car_wash_path(cw), class: "car-wash-card", style: "animation-delay:#{0.05*i}s" do %>
            <div class="card-top">
              <div class="card-avatar"><%= cw.name.first(2).upcase %></div>
              <i class="fas fa-arrow-up-right card-arrow"></i>
            </div>
            <div class="card-name"><%= cw.name %></div>
            <div class="card-meta">
              <div class="card-meta-item">
                <i class="fas fa-location-dot"></i>
                <span><%= [cw.bairro, cw.cidade].select(&:present?).join(", ").presence || cw.address || "Endereço não informado" %></span>
              </div>
              <% if params[:latitude].present? && params[:longitude].present? && cw.latitude && cw.longitude %>
                <% dist = cw.distance_to([params[:latitude].to_f, params[:longitude].to_f], :km) %>
                <div class="card-meta-item"><i class="fas fa-route"></i><span><%= number_with_precision(dist, precision: 1) %> km</span></div>
              <% end %>
              <% reviews = cw.reviews %>
              <% if reviews.any? %>
                <div class="card-meta-item">
                  <i class="fas fa-star" style="color:#facc15;"></i>
                  <span style="color:#fff;font-weight:500;"><%= sprintf('%.1f', reviews.average(:rating).to_f) %></span>
                  <span>(<%= reviews.count %>)</span>
                </div>
              <% else %>
                <div class="card-meta-item"><i class="fas fa-star"></i><span>Sem avaliações</span></div>
              <% end %>
            </div>
            <% service_titles = cw.services.limit(3).pluck(:title) %>
            <% if service_titles.any? %>
              <div class="card-services">
                <% service_titles.each do |t| %>
                  <span class="card-service-tag"><%= t %></span>
                <% end %>
              </div>
            <% end %>
            <div class="card-badge"><i class="fas fa-circle" style="font-size:.4rem"></i> Disponível</div>
          <% end %>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
