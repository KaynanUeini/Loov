<%= form_with(model: operating_hour, url: create_operating_hour_car_wash_path(operating_hour.car_wash), local: true) do |form| %>
  <% if operating_hour.errors.any? %>
    <div class="alert-error">
      <h2><%= pluralize(operating_hour.errors.count, "erro") %> impediram o salvamento:</h2>
      <ul>
        <% operating_hour.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control">
    <%= form.label :day_of_week, "Dia da semana" %>
    <%= form.select :day_of_week, OperatingHour.day_of_weeks.keys.map { |day| [day.humanize, day] }, { prompt: "Selecione o dia" }, required: true %>
  </div>

  <div class="form-control">
    <%= form.label :opens_at, "Abre às" %>
    <%= form.time_field :opens_at, required: true %>
  </div>

  <div class="form-control">
    <%= form.label :closes_at, "Fecha às" %>
    <%= form.time_field :closes_at, required: true %>
  </div>

  <div class="mt-4">
    <%= form.submit class: "btn-primary" %>
  </div>
<% end %>
