{
  "dependencies": {
    "@babel/runtime": "^7.27.6",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "core-js": "^3.30.2",
    "daisyui": "^4.12.10",
    "esbuild": "^0.14.54",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.17"
  },
  "scripts": {
    "build:css": "npx tailwindcss -i app/javascript/application.css -o public/assets/tailwind.css --minify",
    "build:js": "esbuild app/javascript/*.js --bundle --outdir=public/packs --platform=browser --format=iife --global-name=app --sourcemap --minify",
    "build": "yarn build:css && yarn build:js",
    "watch": "esbuild app/javascript/*.js --bundle --outdir=public/packs --platform=browser --format=iife --global-name=app --watch --sourcemap",
    "copy:images": "cp app/javascript/images/Loov.png public/assets/ || echo 'Imagem não encontrada, copie manualmente'"
  },
  "name": "car_wash_app",
  "description": "This README would normally document whatever steps are necessary to get the application up and running.",
  "version": "1.0.0",
  "main": "tailwind.config.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
